function testParseMarkdown_tableListActually():
    markdown = markdownParserParseMarkdown( \
        'A | B\n' + \
        '- | -\n' + \
        '0 | 1\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'A | B'}]}}, \
                {'list': { \
                    'items': [ \
                        { \
                            'parts': [ \
                                {'paragraph': {'spans': [{'text': '| -\n0 | 1'}]}} \
                            ] \
                        } \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_tableListActually')
