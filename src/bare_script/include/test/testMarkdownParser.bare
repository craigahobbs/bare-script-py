function testParseMarkdown_headingAlternateIndented():
    markdown = markdownParserParseMarkdown( \
        '   Foo\n' + \
        '---\n' + \
        '\n' + \
        '  Foo\n' + \
        '-----\n' + \
        '\n' + \
        '  Foo\n' + \
        '  ===\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h2', 'spans': [{'text': '   Foo'}]}}, \
                {'paragraph': {'style': 'h2', 'spans': [{'text': '  Foo'}]}}, \
                {'paragraph': {'style': 'h1', 'spans': [{'text': '  Foo'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_headingAlternateIndented')


function testParseMarkdown_headingAlternateIndentedTooMuch():
