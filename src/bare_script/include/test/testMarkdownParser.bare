include '../markdownParser.bare'
include '../unittest.bare'


function testEscapeMarkdownText():
    unittestEqual( \
        markdownParserEscapeMarkdownText('Escape me: \\ [ ] ( ) < > " \' * _ ~ ` # | -'), \
        'Escape me: \\\\ \\[ \\] \\( \\) \\< \\> \\" \\\' \\* \\_ \\~ \\` \\# \\| \\-' \
    )
endfunction
unittestRunTest('testEscapeMarkdownText')


function testGetMarkdownTitle():
    markdownModel = markdownParserParseMarkdown( \
        'This is some text\n' + \
        '\n' + \
        '## This is the *title*\n' + \
        '\n' + \
        '# This is NOT the *title*\n' + \
        '\n' + \
        'This is more text\n' \
    )
    unittestEqual(markdownParserGetMarkdownTitle(markdownModel), 'This is the title')
endfunction
unittestRunTest('testGetMarkdownTitle')


function testGetMarkdownTitle_link():
    markdownModel = markdownParserParseMarkdown( \
        '# This is the [title](about.html)\n' \
    )
    unittestEqual(markdownParserGetMarkdownTitle(markdownModel), 'This is the title')
endfunction
unittestRunTest('testGetMarkdownTitle_link')


function testGetMarkdownTitle_image():
    markdownModel = markdownParserParseMarkdown( \
        '# This is the ![title](title.jpg)\n' \
    )
    unittestEqual(markdownParserGetMarkdownTitle(markdownModel), 'This is the title')
endfunction
unittestRunTest('testGetMarkdownTitle_image')


function testGetMarkdownTitle_noTitle():
    markdownModel = markdownParserParseMarkdown( \
        'This is some text\n' + \
        '\n' + \
        'This is more text\n' \
    )
    unittestEqual(markdownParserGetMarkdownTitle(markdownModel), null)
endfunction
unittestRunTest('testGetMarkdownTitle_noTitle')


function testGetMarkdownParagraphText():
    markdownModel = markdownParserParseMarkdown( \
        'This is a [link](link.html)\n' + \
        'and some more text\n' + \
        '\n' + \
        'Some other text\n' \
    )
    parts = objectGet(markdownModel, 'parts')
    paragraph = objectGet(arrayGet(parts, 0), 'paragraph')
    unittestEqual(markdownParserGetMarkdownParagraphText(paragraph), 'This is a link\nand some more text')
endfunction
unittestRunTest('testGetMarkdownParagraphText')


function testParseMarkdown():
    markdown = markdownParserParseMarkdown( \
        '# Title\n' + \
        '\n' + \
        'This is a sentence.\n' + \
        'This is another sentence.\n' + \
        '\n' + \
        '\n' + \
        'This is another paragraph.' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'Title'}], 'style': 'h1'}}, \
                {'paragraph': {'spans': [{'text': 'This is a sentence.\nThis is another sentence.'}]}}, \
                {'paragraph': {'spans': [{'text': 'This is another paragraph.'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown')


function testParseMarkdown_lines():
    markdown = markdownParserParseMarkdown([ \
        '# Title', \
        '', \
        'This is a sentence.', \
        'This is another sentence.', \
        null, \
        '', \
        'This is another paragraph.\n\nAnd another.' \
    ])
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'Title'}], 'style': 'h1'}}, \
                {'paragraph': {'spans': [{'text': 'This is a sentence.\nThis is another sentence.'}]}}, \
                {'paragraph': {'spans': [{'text': 'This is another paragraph.'}]}}, \
                {'paragraph': {'spans': [{'text': 'And another.'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_lines')


function testParseMarkdown_tabs():
    markdown = markdownParserParseMarkdown( \
        'This is a tab "\t".\n' + \
        '\n' + \
        ' * List 1 - 1\n' + \
        '\t* List 2 - 1\n' + \
        '\t* List 2 - 2\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'This is a tab "    ".'}]}}, \
                {'list': {'items': [ \
                    {'parts': [ \
                        {'paragraph': {'spans': [{'text': 'List 1 - 1'}]}}, \
                        {'list': {'items': [ \
                            {'parts': [ \
                                {'paragraph': {'spans': [{'text': 'List 2 - 1'}]}} \
                            ]}, \
                            {'parts': [ \
                                {'paragraph': {'spans': [{'text': 'List 2 - 2'}]}} \
                            ]} \
                        ]}} \
                    ]} \
                ]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_tabs')


function testParseMarkdown_empty():
    markdown = markdownParserParseMarkdown('')
    unittestDeepEqual( \
        markdown, \
        {'parts': []} \
    )
endfunction
unittestRunTest('testParseMarkdown_empty')


function testParseMarkdown_horizontalRule():
    markdown = markdownParserParseMarkdown( \
        'Some text\n' + \
        '***\n' + \
        '******\n' + \
        'More text\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'Some text'}]}}, \
                {'hr': 1}, \
                {'hr': 1}, \
                {'paragraph': {'spans': [{'text': 'More text'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_horizontalRule')


function testParseMarkdown_horizontalRuleVariety():
    markdown = markdownParserParseMarkdown( \
        '***\n' + \
        '---\n' + \
        '___\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'hr': 1}, \
                {'hr': 1}, \
                {'hr': 1} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_horizontalRuleVariety')


function testParseMarkdown_horizontalRuleNotEnoughCharacters():
    markdown = markdownParserParseMarkdown( \
        '--\n' + \
        '**\n' + \
        '__\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': '--\n**\n__'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_horizontalRuleNotEnoughCharacters')


function testParseMarkdown_horizontalRuleInitialSpace():
    markdown = markdownParserParseMarkdown( \
        ' ***\n' + \
        '  ***\n' + \
        '   ***\n' + \
        '    ***\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'hr': 1}, \
                {'hr': 1}, \
                {'hr': 1}, \
                {'codeBlock': { \
                    'lines': ['***'], \
                    'startLineNumber': 4 \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_horizontalRuleInitialSpace')


function testParseMarkdown_horizontalRuleMoreThanThreeCharacters():
    markdown = markdownParserParseMarkdown( \
        '-------------------------------------\n' + \
        '*************************************\n' + \
        '_____________________________________\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'hr': 1}, \
                {'hr': 1}, \
                {'hr': 1} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_horizontalRuleMoreThanThreeCharacters')


function testParseMarkdown_horizontalRuleSpaces():
    markdown = markdownParserParseMarkdown( \
        'Some text\n' + \
        ' -  -    --\n' + \
        ' *  *    **\n' + \
        ' _  _    __\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'Some text'}]}}, \
                {'hr': 1}, \
                {'hr': 1}, \
                {'hr': 1} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_horizontalRuleSpaces')


function testParseMarkdown_horizontalRuleBeyondCodeBlock():
    markdown = markdownParserParseMarkdown( \
        '    *****\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'codeBlock': {'lines': ['*****'], 'startLineNumber': 1}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_horizontalRuleBeyondCodeBlock')


function testParseMarkdown_horizontalRuleFollowingCodeBlock():
    markdown = markdownParserParseMarkdown( \
        'This is a horizontal fule immediately following a code block:\n' + \
        '\n' + \
        '    code\n' + \
        '\n' + \
        '---\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'This is a horizontal fule immediately following a code block:'}]}}, \
                {'codeBlock': {'lines': ['code'], 'startLineNumber': 3}}, \
                {'hr': 1} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_horizontalRuleFollowingCodeBlock')


function testParseMarkdown_horizontalRuleSeparatingLists():
    markdown = markdownParserParseMarkdown( \
        '- foo\n' + \
        '***\n' + \
        '- bar\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'list': {'items': [ \
                    {'parts': [ \
                        {'paragraph': {'spans': [{'text': 'foo'}]}} \
                    ]} \
                ]}}, \
                {'hr': 1}, \
                {'list': {'items': [ \
                    {'parts': [ \
                        {'paragraph': {'spans': [{'text': 'bar'}]}} \
                    ]} \
                ]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_horizontalRuleSeparatingLists')


