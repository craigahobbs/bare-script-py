include '../markdownParser.bare'
include '../unittest.bare'


function testMarkdownParse():
    markdown = markdownParse([ \
        '# Title', \
        '', \
        'This is a sentence.', \
        'This is another sentence.', \
        '', \
        '', \
        'This is another paragraph.' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'Title'}], 'style': 'h1'}}, \
                {'paragraph': {'spans': [{'text': 'This is a sentence.\nThis is another sentence.'}]}}, \
                {'paragraph': {'spans': [{'text': 'This is another paragraph.'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse')


