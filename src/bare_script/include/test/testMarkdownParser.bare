                {'codeBlock': {'language': 'javascript', 'lines': ['foo();'], 'startLineNumber': 1}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_fencedCodeBlockLanguageNoSpace')


function testParseMarkdown_fencedCodeBlockSeparatesParagraphs():
