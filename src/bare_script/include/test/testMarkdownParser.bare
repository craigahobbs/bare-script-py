function testParseMarkdown_headingSpans():
    markdown = markdownParserParseMarkdown( \
        '# foo *bar* \\*baz\\*\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h1', 'spans': [ \
                    {'text': 'foo '}, \
                    {'style': {'style': 'italic', 'spans': [{'text': 'bar'}]}}, \
                    {'text': ' *baz*'} \
                ]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_headingSpans')


