function testParseMarkdown_headingIndent():
    markdown = markdownParserParseMarkdown( \
        ' ### foo\n' + \
        '  ## foo\n' + \
        '   # foo\n' + \
        '    # foo\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h3', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h2', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h1', 'spans': [{'text': 'foo'}]}}, \
                {'codeBlock': {'lines': ['# foo'], 'startLineNumber': 4}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_headingIndent')


function testParseMarkdown_headingClosingCharacters():
    markdown = markdownParserParseMarkdown( \
        '## foo ##\n' + \
        '  ###   bar    ###\n' + \
        '### foo ###     \n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h2', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h3', 'spans': [{'text': 'bar'}]}}, \
                {'paragraph': {'style': 'h3', 'spans': [{'text': 'foo'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_headingClosingCharacters')


function testParseMarkdown_headingClosingCharactersLength():
