                {'hr': 1}, \
                {'list': {'items': [ \
                    {'parts': [ \
                        {'paragraph': {'spans': [{'text': 'bar'}]}} \
                    ]} \
                ]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_horizontalRuleSeparatingLists2')


