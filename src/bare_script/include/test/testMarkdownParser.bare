function testParseMarkdown_headingAlternateNoInternalSpaces():
    markdown = markdownParserParseMarkdown( \
        'Foo\n' + \
        '= =\n' + \
        '\n' + \
        'Foo\n' + \
        '--- -\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'Foo\n= ='}]}}, \
                {'paragraph': {'spans': [{'text': 'Foo'}]}}, \
                {'hr': 1} \
            ] \
        } \
    )
endfunction
