        '    Foo\n' + \
        '    ---\n' + \
        '\n' + \
        '    Foo\n' + \
        '---\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'codeBlock': {'lines': ['Foo', '---', '', 'Foo'], 'startLineNumber': 1}}, \
                {'hr': 1} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_headingAlternateIndentedTooMuch')


