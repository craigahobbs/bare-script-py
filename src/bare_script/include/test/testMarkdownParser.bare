function testParseMarkdown_table():
    markdown = markdownParserParseMarkdown( \
        'This is a table:\n' + \
        '\n' + \
        '| Column A | Column B | Column C | Column D |\n' + \
        '| -------- | -------: | :------: | :------- |\n' + \
        '| A0       | B0       | C0       | D0       |\n' + \
        '| A1       | B1       | C1       | D1       |\n' + \
        '\n' + \
        'Neat!\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'This is a table:'}]}}, \
                {'table': { \
                    'headers': [ \
                        [{'text': 'Column A'}], \
                        [{'text': 'Column B'}], \
                        [{'text': 'Column C'}], \
                        [{'text': 'Column D'}] \
                    ], \
                    'aligns': [ \
                        'left', \
                        'right', \
                        'center', \
                        'left' \
                    ], \
                    'rows': [ \
                        [ \
                            [{'text': 'A0'}], \
                            [{'text': 'B0'}], \
                            [{'text': 'C0'}], \
                            [{'text': 'D0'}] \
                        ], \
                        [ \
                            [{'text': 'A1'}], \
                            [{'text': 'B1'}], \
                            [{'text': 'C1'}], \
                            [{'text': 'D1'}] \
                        ] \
                    ] \
                }}, \
                {'paragraph': {'spans': [{'text': 'Neat!'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_table')


function testParseMarkdown_tableCrowded():
    markdown = markdownParserParseMarkdown( \
        'This is a table:\n' + \
        '|Column A|\n' + \
        '|--------|\n' + \
        '|A0      |\n' + \
        'Neat!\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'This is a table:'}]}}, \
                {'table': { \
                    'headers': [[{'text': 'Column A'}]], \
                    'aligns': ['left'], \
                    'rows': [ \
                        [[{'text': 'A0'}]] \
                    ] \
                }}, \
                {'paragraph': {'spans': [{'text': 'Neat!'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_tableCrowded')


function testParseMarkdown_tableNaked():
    markdown = markdownParserParseMarkdown( \
        '| abc | defghi |\n' + \
        ':-: | -----------:\n' + \
        'bar | baz\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'table': { \
                    'headers': [[{'text': 'abc'}], [{'text': 'defghi'}]], \
                    'aligns': ['center', 'right'], \
                    'rows': [ \
                        [[{'text': 'bar'}], [{'text': 'baz'}]] \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_tableNaked')


function testParseMarkdown_tableEscapes():
    markdown = markdownParserParseMarkdown( \
        '| f\\|oo  |\n' + \
        '| ------ |\n' + \
        '| b `\\|` az |\n' + \
        '| b **\\|** im |\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'table': { \
                    'headers': [[{'text': 'f|oo'}]], \
                    'aligns': ['left'], \
                    'rows': [ \
                        [[{'text': 'b '}, {'code': '|'}, {'text': ' az'}]], \
                        [[{'text': 'b '}, {'style': {'style': 'bold', 'spans': [{'text': '|'}]}}, {'text': ' im'}]] \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_tableEscapes')


