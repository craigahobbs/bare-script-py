function testParseMarkdown_horizontalRuleHeaderActually():
    markdown = markdownParserParseMarkdown( \
        'foo\n' + \
        '---\n' + \
        'bar\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
