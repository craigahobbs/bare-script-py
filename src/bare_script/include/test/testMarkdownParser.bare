function testParseMarkdown_headingClosingCharactersEscaped():
    markdown = markdownParserParseMarkdown( \
        '### foo \\###\n' + \
        '## foo #\\##\n' + \
        '# foo \\#\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h3', 'spans': [{'text': 'foo ###'}]}}, \
                {'paragraph': {'style': 'h2', 'spans': [{'text': 'foo ###'}]}}, \
                {'paragraph': {'style': 'h1', 'spans': [{'text': 'foo #'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_headingClosingCharactersEscaped')


