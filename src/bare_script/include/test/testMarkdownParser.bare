function testParseMarkdown_headingAlternate():
    markdown = markdownParserParseMarkdown( \
        'Title *Emphasis*\n' + \
        '================\n' + \
        '\n' + \
        'This is a sentence.\n' + \
        '\n' + \
        'Subtitle *Emphasis*\n' + \
        '-------------------\n' + \
        '\n' + \
        'Some words.\n' \
    )
    unittestDeepEqual( \
        markdown, \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h1', 'spans': [ \
                    {'text': 'Title '}, \
                    {'style': {'style': 'italic', 'spans': [{'text': 'Emphasis'}]}} \
                ]}}, \
                {'paragraph': {'spans': [{'text': 'This is a sentence.'}]}}, \
                {'paragraph': {'style': 'h2', 'spans': [ \
                    {'text': 'Subtitle '}, \
                    {'style': {'style': 'italic', 'spans': [{'text': 'Emphasis'}]}} \
                ]}}, \
                {'paragraph': {'spans': [{'text': 'Some words.'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testParseMarkdown_headingAlternate')


