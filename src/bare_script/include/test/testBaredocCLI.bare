    unittestEqual(arrayLength(logCalls), 1)
    unittestEqual(arrayGet(arrayGet(logCalls, 0), 0), 'test.bare:4: Invalid documentation comment "returns"')
endfunction
unittestRunTest('testBaredocCLI_errorInvalidKeyword')


function testBaredocCLI_noArgs():
