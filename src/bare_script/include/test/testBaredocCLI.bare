function testBaredocCLI_functionDocLeadingTrim():
    # Setup mock
    unittestMockAll({ \
        'systemFetch': { \
            'test.bare': arrayJoin([ \
                '# $function: myFunction', \
                '# $group: My Group', \
                '# $doc:', \
                '# $doc: This is my function', \
                '# $doc:', \
                'function myFunction()', \
                "    systemLog('Hello')", \
                'endfunction' \
            ], '\n') \
        } \
    })

    # Run
    systemGlobalSet('vFiles', '["test.bare"]')
    result = baredocCLI()
    systemGlobalSet('vFiles', null)

    # Verify
    unittestEqual(result, 0)
    expected = jsonStringify({ \
        'functions': [ \
            { \
                'doc': ['This is my function', ''], \
                'group': 'My Group', \
                'name': 'myFunction' \
            } \
        ] \
    })
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['test.bare']], \
        ['systemLog', [expected]] \
    ])
endfunction
unittestRunTest('testBaredocCLI_functionDocLeadingTrim')


function testBaredocCLI_argDocLeadingTrim():
