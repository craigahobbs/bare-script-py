    systemGlobalSet('vFiles', null)

    # Verify
    unittestEqual(result, 0)
    expected = jsonStringify({ \
        'functions': [ \
            { \
                'args': [{'doc': ['The first argument', ''], 'name': 'arg'}], \
                'doc': ['This is my function'], \
                'group': 'My Group', \
                'name': 'myFunction' \
            } \
        ] \
    })
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['test.bare']], \
        ['systemLog', [expected]] \
    ])
endfunction
unittestRunTest('testBaredocCLI_argDocLeadingTrim')


function testBaredocCLI_fetchError():
    # Setup mock - systemFetch returns null for missing file
    unittestMockAll()

    # Run
    systemGlobalSet('vFiles', '["test.bare"]')
    result = baredocCLI()
    systemGlobalSet('vFiles', null)

    # Verify
    unittestEqual(result, 1)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['test.bare']], \
        ['markdownPrint', ['```', 'Failed to load "test.bare"\nerror: No library functions', '```']] \
    ])
endfunction
unittestRunTest('testBaredocCLI_fetchError')


function testBaredocCLI_writeError():
    # Setup mock
    unittestMockAll({ \
        'systemFetch': { \
            'test.bare': arrayJoin([ \
                '# $function: myFunction', \
                '# $group: My Group', \
                '# $doc: This is my function.', \
                'function myFunction(arg1, arg2)', \
                'endfunction' \
            ], '\n') \
        } \
    })

    # Run
    systemGlobalSet('vFiles', '["test.bare"]')
    systemGlobalSet('vOutput', 'test.json')
    result = baredocCLI()
    systemGlobalSet('vFiles', null)
    systemGlobalSet('vOutput', null)

    # Verify
    unittestEqual(result, 1)
    expected = jsonStringify({ \
        "functions": [ \
            { \
                "doc": ["This is my function."], \
                "group": "My Group", \
                "name": "myFunction" \
            } \
        ] \
    })
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['test.bare']], \
        ['systemFetch', [{'url': 'test.json', 'body': expected}]], \
        ['markdownPrint', ['**Error:** Failed to write "test.json"']] \
    ])
endfunction
unittestRunTest('testBaredocCLI_writeError')


function testBaredocCLI_errorNoFunctions():
    # Setup mock
    unittestMockAll()

    # Run
    result = baredocCLI()

    # Verify
    unittestEqual(result, 1)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['markdownPrint', ['```', 'error: No library functions', '```']] \
    ])
endfunction
unittestRunTest('testBaredocCLI_errorNoFunctions')


return


function testBaredocCLI_errorMissingFunctionMembers():
    # Setup mock
    sources = objectNew( \
        'test.bare', arrayNew( \
            '# $function: myFunction', \
            'function myFunction()', \
            "    systemLog('Hello')", \
            'endfunction' \
        ) \
    )
    mock = objectNew( \
        'systemFetch', objectNew( \
            'test.bare', arrayJoin(objectGet(sources, 'test.bare'), stringFromCharCode(10)) \
        ) \
    )
    unittestMockAll(mock)

    # Run
    result = baredocCLI(arrayNew('test.bare'))

    # Verify
    unittestEqual(result, 1)
    mockEnd = unittestMockEnd(mock)
    logCalls = objectGet(mockEnd, 'systemLog')
    unittestEqual(arrayLength(logCalls), 1)
    expected = 'error: Function "myFunction" missing group' + stringFromCharCode(10) + \
        'error: Function "myFunction" missing documentation'
    unittestEqual(arrayGet(arrayGet(logCalls, 0), 0), expected)
endfunction
unittestRunTest('testBaredocCLI_errorMissingFunctionMembers')


