function testBaredocCLI_errorGroupRedefinition():
    # Setup mock
    sources = objectNew( \
        'test.bare', arrayNew( \
            '# $function: myFunction', \
            '# $group: My Group', \
            '# $group: My Other Group', \
            '# $doc: This is my function', \
            'function myFunction()', \
            "    systemLog('Hello')", \
            'endfunction' \
        ) \
    )
    mock = objectNew( \
        'systemFetch', objectNew( \
            'test.bare', arrayJoin(objectGet(sources, 'test.bare'), stringFromCharCode(10)) \
        ) \
    )
    unittestMockAll(mock)

    # Run
    result = baredocCLI(arrayNew('test.bare'))

    # Verify
    unittestEqual(result, 1)
    mockEnd = unittestMockEnd(mock)
    logCalls = objectGet(mockEnd, 'systemLog')
    unittestEqual(arrayLength(logCalls), 1)
    unittestEqual(arrayGet(arrayGet(logCalls, 0), 0), 'test.bare:3: Function "myFunction" group redefinition')
endfunction
unittestRunTest('testBaredocCLI_errorGroupRedefinition')


