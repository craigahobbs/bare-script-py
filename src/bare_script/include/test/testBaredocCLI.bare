include '../baredocCLI.bare'
include '../unittest.bare'
include '../unittestMock.bare'


async function testBaredocCLI():
    # Setup mock
    unittestMockAll({ \
        'systemFetch': { \
            'test.bare': arrayJoin([ \
                '# $function: myFunction', \
                '# $group: My Group', \
                '# $doc: This is my function.', \
                '# $doc:', \
                '# $doc: More on the function.', \
                '# $arg arg1: The first argument', \
                '# $arg arg2: The second argument.', \
                '# $arg arg2:', \
                '# $arg arg2: More on the second argument.', \
                '# $return: The message', \
                'function myFunction(arg1, arg2)', \
                "    message = 'Hello'", \
                '    systemLog(message)', \
                '    return message', \
                'endfunction' \
            ], '\n') \
        } \
    })

    # Run
    systemGlobalSet('vFiles', '["test.bare"]')
    result = baredocCLI()
    systemGlobalSet('vFiles', null)

    # Verify
    unittestEqual(result, 0)
    expected = jsonStringify({ \
        'functions': [ \
            { \
                'args': [ \
                    {'doc': ['The first argument'], 'name': 'arg1'}, \
                    {'doc': ['The second argument.', '', 'More on the second argument.'], 'name': 'arg2'} \
                ], \
                'doc': ['This is my function.', '', 'More on the function.'], \
                'group': 'My Group', \
                'name': 'myFunction', \
                'return': ['The message'] \
            } \
        ] \
    })
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['test.bare']], \
        ['systemLog', [expected]] \
    ])
endfunction
unittestRunTest('testBaredocCLI')


async function testBaredocCLI_help():
    # Setup mock
    unittestMockAll()

    # Run
    systemGlobalSet('vHelp', true)
    result = baredocCLI()
    systemGlobalSet('vHelp', null)

    # Verify
    unittestEqual(result, 1)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['markdownPrint', [ \
            [ \
                '| Variable | Type   | Default | Description                                          |', \
                '|----------|--------|---------|------------------------------------------------------|', \
                "| vFiles   | string | '[]'    | The JSON-encoded list of input source code filenames |", \
                '| vHelp    | bool   |         | Show argument help                                   |', \
                "| vOutput  | string | '-'     | The output file                                      |" \
            ] \
        ]] \
    ])
endfunction
unittestRunTest('testBaredocCLI_help')


async function testBaredocCLI_stdout():
    # Setup mock
    unittestMockAll({ \
        'systemFetch': { \
            'test.bare': arrayJoin([ \
                '# $function: myFunction', \
                '# $group: My Group', \
                '# $doc: This is my function', \
                'function myFunction()', \
                "    systemLog('Hello')", \
                'endfunction' \
            ], '\n') \
        } \
    })

    # Run
    systemGlobalSet('vFiles', '["test.bare"]')
    result = baredocCLI()
    systemGlobalSet('vFiles', null)

    # Verify
    unittestEqual(result, 0)
    expected = jsonStringify({ \
        'functions': [ \
            { \
                'doc': ['This is my function'], \
                'group': 'My Group', \
                'name': 'myFunction' \
            } \
        ] \
    })
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['test.bare']], \
        ['systemLog', [expected]] \
    ])
endfunction
unittestRunTest('testBaredocCLI_stdout')


async function testBaredocCLI_functionDocLeadingTrim():
    # Setup mock
    unittestMockAll({ \
        'systemFetch': { \
            'test.bare': arrayJoin([ \
                '# $function: myFunction', \
                '# $group: My Group', \
                '# $doc:', \
                '# $doc: This is my function', \
                '# $doc:', \
                'function myFunction()', \
                "    systemLog('Hello')", \
                'endfunction' \
            ], '\n') \
        } \
    })

    # Run
    systemGlobalSet('vFiles', '["test.bare"]')
    result = baredocCLI()
    systemGlobalSet('vFiles', null)

    # Verify
    unittestEqual(result, 0)
    expected = jsonStringify({ \
        'functions': [ \
            { \
                'doc': ['This is my function', ''], \
                'group': 'My Group', \
                'name': 'myFunction' \
            } \
        ] \
    })
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['test.bare']], \
        ['systemLog', [expected]] \
    ])
endfunction
unittestRunTest('testBaredocCLI_functionDocLeadingTrim')


