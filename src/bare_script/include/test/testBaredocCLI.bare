            'test.bare': arrayJoin([ \
                '# $function: myFunction', \
                '# $group: My Group', \
                '# $doc: This is my function', \
                '# $arg arg:', \
                '# $arg arg: The first argument', \
                '# $arg arg:', \
                'function myFunction()', \
                "    systemLog('Hello')", \
                'endfunction' \
            ], '\n') \
        } \
    })

    # Run
    systemGlobalSet('vFiles', '["test.bare"]')
