include '../elementModel.bare'
include '../markdownElements.bare'
include '../unittest.bare'
include '../unittestMock.bare'


function testMarkdownElements():
    elements = markdownElements(markdownValidate({ \
        'parts': [ \
            {'paragraph': {'style': 'h1', 'spans': [{'text': 'The Title'}]}}, \
            { \
                'paragraph': { \
                    'spans': [ \
                        {'text': 'This is a sentence. This is '}, \
                        { \
                            'style': { \
                                'style': 'bold', \
                                'spans': [ \
                                    {'text': 'bold and '}, \
                                    {'style': {'style': 'italic', 'spans': [{'text': 'bold-italic'}]}}, \
                                    {'text': '.'} \
                                ] \
                            } \
                        }, \
                        {'text': 'This is '}, \
                        { \
                            'style': {'style': 'strikethrough', 'spans': [{'text': 'strikethrough'}]} \
                        }, \
                        {'text': '.'} \
                    ] \
                } \
            }, \
            { \
                'paragraph': { \
                    'spans': [ \
                        {'text': 'This is a link to the '}, \
                        {'link': { \
                            'href': 'https://craigahobbs.github.io/schema-markdown/doc/', \
                            'title': 'The Schema Markdown Type Model', \
                            'spans': [ \
                                {'style': {'style': 'bold', 'spans': [{'text': 'Schema Markdown'}]}}, \
                                {'text': ' Type Model'} \
                            ] \
                        }} \
                    ] \
                } \
            }, \
            { \
                'paragraph': { \
                    'spans': [ \
                        {'text': 'This is an image: '}, \
                        {'image': { \
                            'src': 'https://craigahobbs.github.io/schema-markdown/doc/doc.svg', \
                            'alt': 'Schema Markdown Documentation Icon', \
                            'title': 'Schema Markdown' \
                        }} \
                    ] \
                } \
            }, \
            { \
                'list': { \
                    'items': [ \
                        { \
                            'parts': [ \
                                {'paragraph': {'spans': [{'text': 'This is a paragraph.'}]}}, \
                                {'paragraph': {'spans': [{'text': 'This is a another paragraph.'}]}} \
                            ] \
                        }, \
                        { \
                            'parts': [ \
                                {'paragraph': {'spans': [{'text': 'This is the second list item.'}]}} \
                            ] \
                        } \
                    ] \
                } \
            }, \
            { \
                'list': { \
                    'start': 10, \
                    'items': [ \
                        { \
                            'parts': [ \
                                {'paragraph': {'spans': [{'text': 'This is a paragraph.'}]}} \
                            ] \
                        } \
                    ] \
                } \
            }, \
            { \
                'quote': { \
                    'parts': [ \
                        {'paragraph': {'spans': [{'text': 'This is a paragraph.'}]}} \
                    ] \
                } \
            }, \
            { \
                'codeBlock': { \
                    'lines': [ \
                        'Line 1', \
                        'Line 2' \
                    ] \
                } \
            } \
        ] \
    }))
    unittestDeepEqual( \
        elementModelValidate(elements), \
        [ \
            {'html': 'h1', 'attr': null, 'elem': [{'text': 'The Title'}]}, \
            { \
                'html': 'p', \
                'elem': [ \
                    {'text': 'This is a sentence. This is '}, \
                    {'html': 'strong', 'elem': [ \
                        {'text': 'bold and '}, \
                        {'html': 'em', 'elem': [{'text': 'bold-italic'}]}, \
                        {'text': '.'} \
                    ]}, \
                    {'text': 'This is '}, \
                    {'html': 'del', 'elem': [{'text': 'strikethrough'}]}, \
                    {'text': '.'} \
                ] \
            }, \
            { \
                'html': 'p', \
                'elem': [ \
                    {'text': 'This is a link to the '}, \
                    { \
                        'html': 'a', \
                        'attr': {'href': 'https://craigahobbs.github.io/schema-markdown/doc/', 'title': 'The Schema Markdown Type Model'}, \
                        'elem': [{'html': 'strong', 'elem': [{'text': 'Schema Markdown'}]}, {'text': ' Type Model'}] \
                    } \
                ] \
            }, \
            { \
                'html': 'p', \
                'elem': [ \
                    {'text': 'This is an image: '}, \
                    { \
                        'html': 'img', \
                        'attr': { \
                            'src': 'https://craigahobbs.github.io/schema-markdown/doc/doc.svg', \
                            'title': 'Schema Markdown', \
                            'alt': 'Schema Markdown Documentation Icon', \
                            'style': 'max-width: 100%;' \
                        } \
                    } \
                ] \
            }, \
            { \
                'html': 'ul', \
                'attr': null, \
                'elem': [ \
                    { \
                        'html': 'li', \
                        'elem': [ \
                            {'html': 'p', 'elem': [{'text': 'This is a paragraph.'}]}, \
                            {'html': 'p', 'elem': [{'text': 'This is a another paragraph.'}]} \
                        ] \
                    }, \
                    { \
                        'html': 'li', \
                        'elem': [ \
                            {'html': 'p', 'elem': [{'text': 'This is the second list item.'}]} \
                        ] \
                    } \
                ] \
            }, \
            { \
                'html': 'ol', \
                'attr': {'start': '10'}, \
                'elem': [ \
                    { \
                        'html': 'li', \
                        'elem': [ \
                            {'html': 'p', 'elem': [{'text': 'This is a paragraph.'}]} \
                        ] \
                    } \
                ] \
            }, \
            { \
                'html': 'blockquote', \
                'elem': [ \
                    {'html': 'p', 'elem': [{'text': 'This is a paragraph.'}]} \
                ] \
            }, \
            [ \
                null, \
                { \
                    'html': 'pre', \
                    'attr': null, \
                    'elem': { \
                        'html': 'code', \
                        'elem': {'text': 'Line 1\nLine 2\n'} \
                    } \
                } \
            ] \
        ] \
    )
endfunction
unittestRunTest('testMarkdownElements')


async function testMarkdownElementsAsync_codeBlockFn(codeBlock):
    return {'html': 'p', 'elem': {'text': systemFetch(objectGet(codeBlock, 'language'))}}
endfunction


async function testMarkdownElementsAsync():
    unittestMockAll({ \
        'systemFetch': { \
            'async-code-block': 'This is the text' \
        } \
    })
    elements = markdownElementsAsync( \
        markdownValidate({ \
            'parts': [ \
                {'paragraph': {'style': 'h1', 'spans': [{'text': 'The Title'}]}}, \
                { \
                    'list': { \
                        'items': [ \
                            { \
                                'parts': [ \
                                    {'codeBlock': {'lines': ['Line 1', 'Line 2']}}, \
                                    {'codeBlock': {'language': 'async-code-block', 'lines': ['Line 1', 'Line 2']}} \
                                ] \
                            } \
                        ] \
                    } \
                }, \
                { \
                    'quote': { \
                        'parts': [ \
                            {'codeBlock': {'lines': ['Line 1', 'Line 2']}}, \
                            {'codeBlock': {'language': 'async-code-block', 'lines': ['Line 1', 'Line 2']}} \
                        ] \
                    } \
                } \
            ] \
        }), \
        { \
            'codeBlocks': { \
                'async-code-block': testMarkdownElementsAsync_codeBlockFn \
            } \
        } \
    )
    unittestDeepEqual( \
        elementModelValidate(elements), \
        [ \
            {'html': 'h1', 'attr': null, 'elem': [{'text': 'The Title'}]}, \
            { \
                'html': 'ul', \
                'attr': null, \
                'elem': [ \
                    { \
                        'html': 'li', \
                        'elem': [ \
                            [ \
                                null, \
                                { \
                                    'html': 'pre', \
                                    'attr': null, \
                                    'elem': {'html': 'code', 'elem': {'text': 'Line 1\nLine 2\n'}} \
                                } \
                            ], \
                            {'html': 'p', 'elem': {'text': 'This is the text'}} \
                        ] \
                    } \
                ] \
            }, \
            { \
                'html': 'blockquote', \
                'elem': [ \
                    [ \
                        null, \
                        { \
                            'html': 'pre', \
                            'attr': null, \
                            'elem': {'html': 'code', 'elem': {'text': 'Line 1\nLine 2\n'}} \
                        } \
                    ], \
                    {'html': 'p', 'elem': {'text': 'This is the text'}} \
                ] \
            } \
        ] \
    )
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['async-code-block']], \
        ['systemFetch', ['async-code-block']] \
    ])
endfunction
unittestRunTest('testMarkdownElementsAsync')


function testMarkdownElements_headerIDs():
    elements = markdownElements( \
        markdownValidate({ \
            'parts': [ \
                { \
                    'paragraph': { \
                        'style': 'h1', \
                        'spans': [ \
                            {'text': "The @#$ Page's Title!!"} \
                        ] \
                    } \
                } \
            ] \
        }), \
        { \
            'headerIds': true \
        } \
    )
    unittestDeepEqual( \
        elementModelValidate(elements), \
        [ \
            { \
                'html': 'h1', \
                'attr': {'id': 'the-pages-title'}, \
                'elem': [ \
                    {'text': "The @#$ Page's Title!!"} \
                ] \
            } \
        ] \
    )
endfunction
unittestRunTest('testMarkdownElements_headerIDs')


function testMarkdownElements_headerIDsURLFn_urlFn(url):
    return '#url=README.md&' + stringSlice(url, 1)
endfunction


function testMarkdownElements_headerIDsURLFn():
    elements = markdownElements( \
        markdownValidate({ \
            'parts': [ \
                { \
                    'paragraph': { \
                        'style': 'h1', \
                        'spans': [ \
                            {'text': "The @#$ Page's Title!!"} \
                        ] \
                    } \
                } \
            ] \
        }), \
        { \
            'headerIds': true, \
            'urlFn': testMarkdownElements_headerIDsURLFn_urlFn \
        } \
    )
    unittestDeepEqual( \
        elementModelValidate(elements), \
        [ \
            { \
                'html': 'h1', \
                'attr': {'id': 'url=README.md&the-pages-title'}, \
                'elem': [ \
                    {'text': "The @#$ Page's Title!!"} \
                ] \
            } \
        ] \
    )
endfunction
unittestRunTest('testMarkdownElements_headerIDsURLFn')


function testMarkdownElements_duplicateHeaderIDs():
    elements = markdownElements( \
        markdownValidate({ \
            'parts': [ \
                { \
                    'paragraph': { \
                        'style': 'h1', \
                        'spans': [ \
                            {'text': 'The Title'} \
                        ] \
                    } \
                }, \
                { \
                    'list': { \
                        'items': [ \
                            { \
                                'parts': [ \
                                    { \
                                        'paragraph': { \
                                            'style': 'h2', \
                                            'spans': [ \
                                                {'text': 'The Title'} \
                                            ] \
                                        } \
                                    } \
                                ] \
                            } \
                        ] \
                    } \
                } \
            ] \
        }), \
        { \
            'headerIds': true \
        } \
    )
    unittestDeepEqual( \
        elementModelValidate(elements), \
        [ \
            { \
                'html': 'h1', \
                'attr': {'id': 'the-title'}, \
                'elem': [ \
                    {'text': 'The Title'} \
                ] \
            }, \
            { \
                'html': 'ul', \
                'attr': null, \
                'elem': [ \
                    { \
                        'html': 'li', \
                        'elem': [ \
                            { \
                                'html': 'h2', \
                                'attr': {'id': 'the-title2'}, \
                                'elem': [ \
                                    {'text': 'The Title'} \
                                ] \
                            } \
                        ] \
                    } \
                ] \
            } \
        ] \
    )
endfunction
unittestRunTest('testMarkdownElements_duplicateHeaderIDs')


