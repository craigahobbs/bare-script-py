function testMarkdownElements_codeBlockWithLanguage():
    elements = markdownElements(markdownValidate({ \
        'parts': [ \
            { \
                'codeBlock': { \
                    'language': 'javascript', \
                    'lines': [ \
                        'foo();', \
                        'bar();' \
                    ] \
                } \
            } \
        ] \
    }))
    unittestDeepEqual( \
        elementModelValidate(elements), \
        [ \
            [ \
                null, \
                { \
                    'html': 'pre', \
                    'attr': null, \
                    'elem': { \
                        'html': 'code', \
                        'elem': [ \
                            {'text': 'foo();\nbar();\n'} \
                        ] \
                    } \
                } \
            ] \
        ] \
    )
endfunction
unittestRunTest('testMarkdownElements_codeBlockWithLanguage')


function testMarkdownElements_codeBlockWithLanguageOverride_fooscript(codeBlock):
    return {'text': objectGet(codeBlock, 'language') + ', ' + jsonStringify(objectGet(codeBlock, 'lines'))}
endfunction


function testMarkdownElements_codeBlockWithLanguageOverride():
    codeBlocks = { \
        'fooscript': testMarkdownElements_codeBlockWithLanguageOverride_fooscript \
    }
    elements = markdownElements( \
        markdownValidate({ \
            'parts': [ \
                { \
                    'codeBlock': { \
                        'language': 'fooscript', \
                        'lines': [ \
                            'foo();', \
                            'bar();' \
                        ] \
                    } \
                } \
            ] \
        }), \
        { \
            'codeBlocks': codeBlocks \
        } \
    )
    unittestDeepEqual( \
        elementModelValidate(elements), \
        [ \
            {'text': 'fooscript, ["foo();","bar();"]'} \
        ] \
    )
endfunction
unittestRunTest('testMarkdownElements_codeBlockWithLanguageOverride')


function testMarkdownElements_table():
    elements = markdownElements(markdownValidate({ \
        'parts': [ \
            { \
                'table': { \
                    'headers': [[{'text': 'Column A'}], [{'text': 'Column B'}]], \
                    'aligns': ['left', 'right'], \
                    'rows': [ \
                        [[{'text': 'A0'}], [{'text': 'B0'}]], \
                        [[{'text': 'A1'}], [{'text': 'B1'}]] \
                    ] \
                } \
            } \
        ] \
    }))
    unittestDeepEqual( \
        elementModelValidate(elements), \
        [ \
            { \
                'html': 'table', \
                'elem': [ \
                    { \
                        'html': 'thead', \
                        'elem': { \
                            'html': 'tr', \
                            'elem': [ \
                                {'html': 'th', 'attr': {'style': 'text-align: left'}, 'elem': [{'text': 'Column A'}]}, \
                                {'html': 'th', 'attr': {'style': 'text-align: right'}, 'elem': [{'text': 'Column B'}]} \
                            ] \
                        } \
                    }, \
                    { \
                        'html': 'tbody', \
                        'elem': [ \
                            { \
                                'html': 'tr', \
                                'elem': [ \
                                    {'html': 'td', 'attr': {'style': 'text-align: left'}, 'elem': [{'text': 'A0'}]}, \
                                    {'html': 'td', 'attr': {'style': 'text-align: right'}, 'elem': [{'text': 'B0'}]} \
                                ] \
                            }, \
                            { \
                                'html': 'tr', \
                                'elem': [ \
                                    {'html': 'td', 'attr': {'style': 'text-align: left'}, 'elem': [{'text': 'A1'}]}, \
                                    {'html': 'td', 'attr': {'style': 'text-align: right'}, 'elem': [{'text': 'B1'}]} \
                                ] \
                            } \
                        ] \
                    } \
                ] \
            } \
        ] \
    )
endfunction
unittestRunTest('testMarkdownElements_table')


