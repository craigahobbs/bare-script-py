function testMarkdownElements_lineBreak():
    elements = markdownElements(markdownValidate({ \
        'parts': [ \
            { \
                'paragraph': { \
                    'spans': [ \
                        {'text': 'This is a line break'}, \
                        {'br': 1}, \
                        {'text': 'some more text'} \
                    ] \
                } \
            } \
        ] \
    }))
    unittestDeepEqual( \
        elementModelValidate(elements), \
        [ \
            { \
                'html': 'p', \
                'elem': [ \
                    {'text': 'This is a line break'}, \
                    {'html': 'br'}, \
                    {'text': 'some more text'} \
                ] \
            } \
        ] \
    )
endfunction
unittestRunTest('testMarkdownElements_lineBreak')


function testMarkdownElements_horizontalRule():
    elements = markdownElements(markdownValidate({ \
        'parts': [ \
            {'paragraph': {'spans': [{'text': 'Some text'}]}}, \
            {'hr': 1}, \
            {'paragraph': {'spans': [{'text': 'More text'}]}} \
        ] \
    }))
    unittestDeepEqual( \
        elementModelValidate(elements), \
        [ \
            {'html': 'p', 'elem': [{'text': 'Some text'}]}, \
            {'html': 'hr'}, \
            {'html': 'p', 'elem': [{'text': 'More text'}]} \
        ] \
    )
endfunction
unittestRunTest('testMarkdownElements_horizontalRule')


