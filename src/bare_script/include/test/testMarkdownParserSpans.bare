    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': { \
                    'spans': [ \
                        {'linkRef': {'spans': [{'text': '[link [foo [bar]'}]}}, \
                        {'text': ']](/uri)\n'}, \
                        {'linkRef': {'spans': [{'text': '[link]'}]}}, \
                        {'text': ' bar](/uri)\n'}, \
                        {'link': {'href': '/uri', 'spans': [{'text': 'link [bar'}]}}, \
                        {'text': '\n'}, \
                        {'link': {'href': '/uri', 'spans': [{'text': 'link [bar'}]}} \
