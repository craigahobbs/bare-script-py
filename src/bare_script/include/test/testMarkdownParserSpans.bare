            {'codeBlock': { \
                'lines': ['[foo]: /url "title"'], \
                'startLineNumber': 1 \
            }}, \
            {'paragraph': { \
                'spans': [ \
                    {'linkRef': { \
                        'spans': [ \
                            {'text': '[foo]'} \
                        ] \
                    }} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkDefinitionCodeBlock')


