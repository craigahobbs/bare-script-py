function testMarkdownParse_lineBreak():
   markdown = markdownParse([ \
        'This is a line break  ', \
        '  this is not', \
        'and this is not  ', \
        '', \
        'This is another paragraph.' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': { \
                    'spans': [ \
                        {'text': 'This is a line break'}, \
                        {'br': 1}, \
                        {'text': '  this is not\nand this is not  '} \
                    ] \
                }}, \
                {'paragraph': { \
                    'spans': [ \
                        {'text': 'This is another paragraph.'} \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_lineBreak')


