include '../markdownParser.bare'
include '../unittest.bare'


function testMarkdownParse_spans():
    markdown = markdownParse([ \
        'These are some basic styles: **bold**, *italic*, ***bold-italic***.', \
        '', \
        'This is a [link](https://foo.com) and so is [this](https://bar.com "Bar").', \
        '', \
        'This is another link: <https://foo.com>', \
        '', \
        'This is an ![image](https://foo.com/foo.jpg) and so is ![this](https://bar.com/bar.jpg "Bar").', \
        '', \
        'This is code `foo = 2 * bar`.' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': { \
                    'spans': [ \
                        {'text': 'These are some basic styles: '}, \
                        {'style': {'style': 'bold', 'spans': [{'text': 'bold'}]}}, \
                        {'text': ', '}, \
                        {'style': {'style': 'italic', 'spans': [{'text': 'italic'}]}}, \
                        {'text': ', '}, \
                        {'style': {'spans': [{'style': {'spans': [{'text': 'bold-italic'}], 'style': 'italic'}}], 'style': 'bold'}}, \
                        {'text': '.'} \
                    ] \
                }}, \
                {'paragraph': { \
                    'spans': [ \
                        {'text': 'This is a '}, \
                        {'link': {'href': 'https://foo.com', 'spans': [{'text': 'link'}]}}, \
                        {'text': ' and so is '}, \
                        {'link': {'href': 'https://bar.com', 'spans': [{'text': 'this'}], 'title': 'Bar'}}, \
                        {'text': '.'} \
                    ] \
                }}, \
                {'paragraph': { \
                    'spans': [ \
                        {'text': 'This is another link: '}, \
                        {'link': {'href': 'https://foo.com', 'spans': [{'text': 'https://foo.com'}]}} \
                    ] \
                }}, \
                {'paragraph': { \
                    'spans': [ \
                        {'text': 'This is an '}, \
                        {'image': {'alt': 'image', 'src': 'https://foo.com/foo.jpg'}}, \
                        {'text': ' and so is '}, \
                        {'image': {'alt': 'this', 'src': 'https://bar.com/bar.jpg', 'title': 'Bar'}}, \
                        {'text': '.'} \
                    ] \
                }}, \
                {'paragraph': { \
                    'spans': [ \
                        {'text': 'This is code '}, \
                        {'code': 'foo = 2 * bar'}, \
                        {'text': '.'} \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_spans')


function testMarkdownParse_nestedSpans():
    markdown = markdownParse([ \
        'This is a [link **with *formatting***](https://foo.com)' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': { \
                    'spans': [ \
                        {'text': 'This is a '}, \
                        { \
                            'link': { \
                                'href': 'https://foo.com', \
                                'spans': [ \
                                    {'text': 'link '}, \
                                    {'style': {'style': 'bold', 'spans': [ \
                                        {'text': 'with '}, \
                                        {'style': {'style': 'italic', 'spans': [{'text': 'formatting'}]}} \
                                    ]}} \
                                ] \
                            } \
                        } \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_nestedSpans')


function testMarkdownParse_spansSpaces():
    markdown = markdownParse([ \
        '***no *** *** no*** **no ** ** no** *no * * no*' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': { \
                    'spans': [ \
                        {'text': '***no *** *** no*** **no ** ** no** *no * * no*'} \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_spansSpaces')


function testMarkdownParse_spansSpacesHangFix():
    markdown = markdownParse([ \
        '**a                               b', \
        '*a                                b', \
        '__a                               b', \
        '_a                                b', \
        '~a                                b' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': { \
                    'spans': [ \
                        { \
                            'text': '**a                               b\n' + \
                                    '*a                                b\n' + \
                                    '__a                               b\n' + \
                                    '_a                                b\n' + \
                                    '~a                                b' \
                        } \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_spansSpacesHangFix')


function testMarkdownParse_entityReferences():
    markdown = markdownParse([ \
        '&nbsp; &amp; &copy; &AElig; &Dcaron;', \
        '&frac34; &HilbertSpace; &DifferentialD;', \
        '&ClockwiseContourIntegral; &ngE;' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': { \
                    'spans': [ \
                        {'text': '\u00a0 & \u00a9 &AElig; &Dcaron;\n' + \
                                 '\u00be &HilbertSpace; &DifferentialD;\n' + \
                                 '&ClockwiseContourIntegral; &ngE;'} \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_entityReferences')


function testMarkdownParse_entityDecimalNumericCharacterReferences():
