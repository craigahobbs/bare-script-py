function testMarkdownParse_boldNested():
    markdown = markdownParse('****foo****')
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': { \
                    'spans': [ \
                        {'style': { \
                            'spans': [ \
                                {'style': {'spans': [{'text': 'foo'}], 'style': 'bold'}} \
                            ], \
