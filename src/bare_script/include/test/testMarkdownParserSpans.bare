                        'title': 'moon-link', \
                        'spans': [ \
                            {'linkRef': { \
                                'spans': [ \
                                    {'image': {'alt': 'moon', 'src': 'moon.jpg', 'title': 'moon-image'}} \
                                ] \
                            }} \
                        ] \
                    }} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkAndImageReference')


