function testMarkdownParse_entityNonEntities():
    markdown = markdownParse([ \
        '&nbsp &x; &#; &#x;', \
        '&#87654321;', \
        '&#abcdef0;', \
        '&ThisIsNotDefined; &hi?;' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': { \
                    'spans': [ \
                        {'text': '&nbsp &x; &#; &#x;\n' + \
                                 '&#87654321;\n' + \
                                 '&#abcdef0;\n' + \
                                 '&ThisIsNotDefined; &hi?;'} \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_entityNonEntities')


