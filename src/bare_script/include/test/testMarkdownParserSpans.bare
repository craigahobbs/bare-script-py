                                        ] \
                                    }} \
                                ] \
                            }} \
                        ] \
                    }} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkReferenceAndImageReferenceMinimal')


function testMarkdownParse_linkReferenceAndImageReferenceMultiline():
    markdown = markdownParse([ \
        '[', \
        ' ![', \
        '  moon', \
        '  ][', \
        '  img', \
        '  ]', \
        '][', \
        ' ref', \
        ']', \
        '', \
        '[ref]: /uri "moon-link"', \
        '[img]: moon.jpg "moon-image"' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    {'linkRef': { \
                        'spans': [ \
                            {'link': { \
                                'href': '/uri', \
                                'spans': [ \
                                    {'linkRef': { \
                                        'spans': [ \
                                            {'image': {'alt': ' moon ', 'src': 'moon.jpg', 'title': 'moon-image'}} \
                                        ] \
                                    }} \
                                ], \
                                'title': 'moon-link' \
                            }} \
                        ] \
                    }} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkReferenceAndImageReferenceMultiline')


