function testMarkdownParse_linkReferenceCannotContainLinks():
    markdown = markdownParse([ \
        '[foo [bar](/uri)][ref]', \
        '', \
        '[ref]: /uri' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    {'link': {'href': '/uri', 'spans': [{'text': 'foo [bar'}]}}, \
                    {'text': ']'}, \
                    {'linkRef': { \
                        'spans': [ \
                            {'link': {'href': '/uri', 'spans': [{'text': 'ref'}]}} \
                        ] \
                    }} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkReferenceCannotContainLinks')


function testMarkdownParse_linkReferencePrecedence():
    markdown = markdownParse([ \
        '[foo]()', \
        '', \
        '[foo]: /url1' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    {'link': {'href': '', 'spans': [{'text': 'foo'}]}} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkReferencePrecedence')


function testMarkdownParse_linkReferencePrecedence2():
    markdown = markdownParse([ \
        '[foo](not a link)', \
        '', \
        '[foo]: /url1' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    {'linkRef': { \
                        'spans': [ \
                            {'link': {'href': '/url1', 'spans': [{'text': 'foo'}]}} \
                        ] \
                    }}, \
                    {'text': '(not a link)'} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkReferencePrecedence2')


function testMarkdownParse_linkReferenceConsecutive():
    markdown = markdownParse([ \
        '[foo][bar][baz]', \
        '', \
        '[baz]: /url' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    { \
                        'linkRef': { \
                            'spans': [ \
                                {'linkRef': {'spans': [{'text': '[foo]'}]}}, \
                                {'text': '[bar]'} \
                            ] \
                        } \
                    }, \
                    { \
                        'linkRef': { \
                            'spans': [ \
                                {'link': {'href': '/url', 'spans': [{'text': 'baz'}]}} \
                            ] \
                        } \
                    } \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkReferenceConsecutive')


function testMarkdownParse_linkReferenceEmptyRef():
    markdown = markdownParse([ \
        '[]', \
        '', \
        '[]: /uri' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    { \
                        'linkRef': { \
                            'spans': [ \
                                {'text': '[]'} \
                            ] \
                        } \
                    } \
                ] \
            }}, \
            {'paragraph': { \
                'spans': [ \
                    { \
                        'linkRef': { \
                            'spans': [ \
                                {'text': '[]'} \
                            ] \
                        } \
                    }, \
                    {'text': ': /uri'} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkReferenceEmptyRef')


function testMarkdownParse_imageReference():
   markdown = markdownParse([ \
        '![foo *bar*]', \
        '', \
        '[foo *bar*]: train.jpg "train & tracks"' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    { \
                        'linkRef': { \
                            'spans': [ \
                                {'image': {'alt': 'foo *bar*', 'src': 'train.jpg', 'title': 'train & tracks'}} \
                            ] \
                        } \
                    } \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_imageReference')


function testMarkdownParse_imageReferenceAltText():
    markdown = markdownParse([ \
        '![foo *bar*][foobar]', \
        '', \
        '[FOOBAR]: train.jpg "train & tracks"' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    { \
                        'linkRef': { \
                            'spans': [ \
                                {'image': {'alt': 'foo *bar*', 'src': 'train.jpg', 'title': 'train & tracks'}} \
                            ] \
                        } \
                    } \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_imageReferenceAltText')


