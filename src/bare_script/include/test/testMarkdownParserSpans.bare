function testMarkdownParse_linkReferenceAndImageMissingLinkReference():
    markdown = markdownParse([ \
        '[![moon](moon.jpg "moon-image")][ref]' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    {'linkRef': { \
                        'spans': [ \
                            {'text': '[![moon](moon.jpg "moon-image")][ref]'} \
                        ] \
                    }} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkReferenceAndImageMissingLinkReference')


function testMarkdownParse_linkReferenceAndImageReference():
    markdown = markdownParse([ \
        '[![moon][img]][ref]', \
        '', \
        '[ref]: /uri "moon-link"', \
        '[img]: moon.jpg "moon-image"' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    {'linkRef': { \
                        'spans': [ \
                            {'link': { \
                                'href': '/uri', \
                                'spans': [ \
                                    {'linkRef': { \
                                        'spans': [ \
                                            {'image': {'alt': 'moon', 'src': 'moon.jpg', 'title': 'moon-image'}} \
                                        ] \
                                    }} \
                                ], \
                                'title': 'moon-link' \
                            }} \
                        ] \
                    }} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkReferenceAndImageReference')


function testMarkdownParse_linkReferenceAndImageReferenceEscapeStart():
    markdown = markdownParse([ \
        '\\[![moon][img]][ref]', \
        '', \
        '[ref]: /uri "moon-link"', \
        '[img]: moon.jpg "moon-image"' \
    ])
    unittestDeepEqual(markdownValidate(markdown), { \
        'parts': [ \
            {'paragraph': { \
                'spans': [ \
                    {'text': '\\'}, \
                    {'linkRef': { \
                        'spans': [ \
                            {'link': { \
                                'href': '/uri', \
                                'spans': [ \
                                    {'linkRef': { \
                                        'spans': [ \
                                            {'image': {'alt': 'moon', 'src': 'moon.jpg', 'title': 'moon-image'}} \
                                        ] \
                                    }} \
                                ], \
                                'title': 'moon-link' \
                            }} \
                        ] \
                    }} \
                ] \
            }} \
        ] \
    })
endfunction
unittestRunTest('testMarkdownParse_linkReferenceAndImageReferenceEscapeStart')


function testMarkdownParse_linkReferenceAndImageReferenceMinimal():
