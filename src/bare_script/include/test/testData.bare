include '../data.bare'
include '../unittest.bare'
include '../unittestMock.bare'


#
# dataParseCSV tests
#


function testDataParseCSV():
    unittestMockAll()
    data = dataParseCSV( \
        'ColumnA,Column B,ColumnC,ColumnD\n' + \
        '1,abc,"10","xyz"\n' + \
        '2,def,"11","pdq"\n' \
    )
    unittestDeepEqual(data, [ \
        {'ColumnA': 1, 'Column B': 'abc', 'ColumnC': 10, 'ColumnD': 'xyz'}, \
        {'ColumnA': 2, 'Column B': 'def', 'ColumnC': 11, 'ColumnD': 'pdq'} \
    ])
    unittestDeepEqual(unittestMockEnd(), [])
endfunction
unittestRunTest('testDataParseCSV')


function testDataParseCSV_array():
    data = dataParseCSV([ \
        'A,B\na1,b1', \
        'a2,b2' \
    ])
    unittestDeepEqual(data, [ \
        {'A': 'a1', 'B': 'b1'}, \
        {'A': 'a2', 'B': 'b2'} \
    ])
endfunction
unittestRunTest('testDataParseCSV_array')


function testDataParseCSV_shortRow():
    data = dataParseCSV( \
        'A,B\n' + \
        'a1,b1\n' + \
        'a2\n' \
    )
    unittestDeepEqual(data, [ \
        {'A': 'a1', 'B': 'b1'}, \
        {'A': 'a2', 'B': null} \
    ])
endfunction
unittestRunTest('testDataParseCSV_shortRow')


function testDataParseCSV_blankLines():
    data = dataParseCSV([ \
        'A,B', \
        '  ', \
        'a1,b1', \
        '', \
        'a2,b2' \
    ])
    unittestDeepEqual(data, [ \
        {'A': 'a1', 'B': 'b1'}, \
        {'A': 'a2', 'B': 'b2'} \
    ])
endfunction
unittestRunTest('testDataParseCSV_blankLines')


function testDataParseCSV_quotes():
    data = dataParseCSV( \
        'A,B\n' + \
        '"a,1",b1\n' + \
        'a2,"b,2"\n' \
    )
    unittestDeepEqual(data, [ \
        {'A': 'a,1', 'B': 'b1'}, \
        {'A': 'a2', 'B': 'b,2'} \
    ])
endfunction
unittestRunTest('testDataParseCSV_quotes')


function testDataParseCSV_quotesEscaped():
    data = dataParseCSV( \
        'A,B\n' + \
        '"a,""1""",b1\n' + \
        'a2,"b,""2"""\n' \
    )
    unittestDeepEqual(data, [ \
        {'A': 'a,"1"', 'B': 'b1'}, \
        {'A': 'a2', 'B': 'b,"2"'} \
    ])
endfunction
unittestRunTest('testDataParseCSV_quotesEscaped')


function testDataParseCSV_spaces():
    data = dataParseCSV([ \
        'A,B', \
        ' a1,b1 ', \
        ' "a2","b2" ' \
    ])
    unittestDeepEqual(data, [ \
        {'A': ' a1', 'B': 'b1 '}, \
        {'A': ' "a2"', 'B': 'b2'} \
    ])
endfunction
unittestRunTest('testDataParseCSV_spaces')


function testDataParseCSV_emptyFile():
    data = dataParseCSV('')
    unittestDeepEqual(data, [])
endfunction
unittestRunTest('testDataParseCSV_emptyFile')


#
# dataValidate tests
#


function testValidateData():
    data = [ \
        {'A': 1, 'B': '5', 'C': 10}, \
        {'A': 2, 'B': '6', 'C': null}, \
        {'A': 3, 'B': '7', 'C': null} \
    ]
    unittestDeepEqual(dataValidate(data), { \
        'A': 'number', \
        'B': 'string', \
        'C': 'number' \
    })
    unittestDeepEqual(data, [ \
        {'A': 1, 'B': '5', 'C': 10}, \
        {'A': 2, 'B': '6', 'C': null}, \
        {'A': 3, 'B': '7', 'C': null} \
    ])
endfunction
unittestRunTest('testValidateData')


function testValidateData_csv():
    data = [ \
        {'A': 1, 'B': '5', 'C': 10}, \
        {'A': 2, 'B': 6, 'C': null}, \
        {'A': 3, 'B': '7', 'C': 'null'}, \
        {'A': 4, 'B': 8, 'C': ''} \
    ]
    unittestDeepEqual(dataValidate(data, true), { \
        'A': 'number', \
        'B': 'number', \
        'C': 'number' \
    })
    unittestDeepEqual(data, [ \
        {'A': 1, 'B': 5, 'C': 10}, \
        {'A': 2, 'B': 6, 'C': null}, \
        {'A': 3, 'B': 7, 'C': null}, \
        {'A': 4, 'B': 8, 'C': null} \
    ])
endfunction
unittestRunTest('testValidateData_csv')


function testValidateData_string():
    data = [ \
        {'str': 'asdf'}, \
        {'str': '5'}, \
        {'date': null} \
    ]
    unittestDeepEqual(dataValidate(data, true), { \
        'str': 'string' \
    })

    unittestDeepEqual(data, [ \
        {'str': 'asdf'}, \
        {'str': '5'}, \
        {'date': null} \
    ])
endfunction
unittestRunTest('testValidateData_string')


function testValidateData_datetime():
    data = [ \
        {'date': datetimeISOParse('2022-08-30T00:00:00+00:00')}, \
        {'date': '2022-08-30'}, \
        {'date': '2022-08-30T11:04:00Z'}, \
        {'date': '2022-08-30T11:04:00-07:00'}, \
        {'date': null} \
    ]
    unittestDeepEqual(dataValidate(data, true), { \
        'date': 'datetime' \
    })

    unittestDeepEqual(data, [ \
        {'date': datetimeISOParse('2022-08-30T00:00:00+00:00')}, \
        {'date': datetimeISOParse('2022-08-30')}, \
        {'date': datetimeISOParse('2022-08-30T11:04:00+00:00')}, \
        {'date': datetimeISOParse('2022-08-30T18:04:00+00:00')}, \
        {'date': null} \
    ])
endfunction
unittestRunTest('testValidateData_datetime')


function testValidateData_datetimeString():
    data = [ \
        {'date': '2022-08-30'}, \
        {'date': datetimeISOParse('2022-08-30T00:00:00+00:00')}, \
        {'date': '2022-08-30T11:04:00Z'}, \
        {'date': '2022-08-30T11:04:00-07:00'}, \
        {'date': null}, \
        {'date': 'null'}, \
        {'date': ''} \
    ]
    unittestDeepEqual(dataValidate(data, true), { \
        'date': 'datetime' \
    })

    unittestDeepEqual(data, [ \
        {'date': datetimeISOParse('2022-08-30')}, \
        {'date': datetimeISOParse('2022-08-30T00:00:00+00:00')}, \
        {'date': datetimeISOParse('2022-08-30T11:04:00+00:00')}, \
        {'date': datetimeISOParse('2022-08-30T18:04:00+00:00')}, \
        {'date': null}, \
        {'date': null}, \
        {'date': null} \
    ])
endfunction
unittestRunTest('testValidateData_datetimeString')


function testValidateData_bool():
    data = [ \
        {'A': 1, 'B': true}, \
        {'A': 2, 'B': false}, \
        {'A': 3, 'B': 'true'}, \
        {'A': 4, 'B': 'false'}, \
        {'A': 5, 'B': null} \
    ]
    unittestDeepEqual(dataValidate(data, true), { \
        'A': 'number', \
        'B': 'boolean' \
    })
    unittestDeepEqual(data, [ \
        {'A': 1, 'B': true}, \
        {'A': 2, 'B': false}, \
        {'A': 3, 'B': true}, \
        {'A': 4, 'B': false}, \
        {'A': 5, 'B': null} \
    ])
endfunction
unittestRunTest('testValidateData_bool')


function testValidateData_boolString():
    data = [ \
        {'A': 1, 'B': 'true'}, \
        {'A': 2, 'B': 'false'}, \
        {'A': 3, 'B': true}, \
        {'A': 4, 'B': false}, \
        {'A': 5, 'B': null}, \
        {'A': 5, 'B': 'null'}, \
        {'A': 5, 'B': ''} \
    ]
    unittestDeepEqual(dataValidate(data, true), { \
        'A': 'number', \
        'B': 'boolean' \
    })
    unittestDeepEqual(data, [ \
        {'A': 1, 'B': true}, \
        {'A': 2, 'B': false}, \
        {'A': 3, 'B': true}, \
        {'A': 4, 'B': false}, \
        {'A': 5, 'B': null}, \
        {'A': 5, 'B': null}, \
        {'A': 5, 'B': null} \
    ])
endfunction
unittestRunTest('testValidateData_boolString')


function testValidateData_unknown():
    data = [ \
        {'A': 1, 'B': regexNew('^foo')}, \
        {'A': 2, 'B': regexNew('^bar')} \
    ]
    unittestDeepEqual(dataValidate(data, true), { \
        'A': 'number' \
    })
    unittestDeepEqual(data, [ \
        {'A': 1, 'B': regexNew('^foo')}, \
        {'A': 2, 'B': regexNew('^bar')} \
    ])
endfunction
unittestRunTest('testValidateData_unknown')


function testValidateData_undetermined():
    data = [ \
        {'A': '', 'B': 'null'}, \
        {'A': 2, 'B': ''} \
    ]
    unittestDeepEqual(dataValidate(data, true), { \
        'A': 'number', \
        'B': 'string' \
    })
    unittestDeepEqual(data, [ \
        {'A': null, 'B': null}, \
        {'A': 2, 'B': ''} \
    ])
endfunction
unittestRunTest('testValidateData_undetermined')


function testValidateData_numberError():
    unittestMockAll()
    data = [ \
        {'A': 1}, \
        {'A': '2'} \
    ]
    unittestEqual(dataValidate(data), null)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemLogDebug', ['data.bare: dataValidate - Invalid "A" field value "2", expected type number']] \
    ])
endfunction
unittestRunTest('testValidateData_numberError')


