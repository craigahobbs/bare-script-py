function testDataAggregate_stddev():
    data = [ \
        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1, 'C': 6}, \
        {'A': 1, 'B': 1}, \
        {'A': 1, 'B': 2, 'C': 7}, \
        {'A': 1, 'B': 2, 'C': 10}, \
        {'A': 2, 'B': 1, 'C': 5}, \
        {'A': 2, 'B': 1, 'C': 10}, \
        {'A': 2, 'B': 2} \
    ]
    aggregation = { \
        'categories': ['A', 'B'], \
        'measures': [ \
            {'field': 'C', 'function': 'stddev'} \
        ] \
    }
    result = dataAggregate(data, aggregation)
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': 1, 'C': 0.5}, \
        {'A': 1, 'B': 2, 'C': 1.5}, \
        {'A': 2, 'B': 1, 'C': 2.5}, \
        {'A': 2, 'B': 2, 'C': null} \
    ])
endfunction
unittestRunTest('testDataAggregate_stddev')


function testDataAggregate_sum():
    data = [ \
        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1, 'C': 6}, \
        {'A': 1, 'B': 1}, \
        {'A': 1, 'B': 2, 'C': 7}, \
        {'A': 1, 'B': 2, 'C': 8}, \
        {'A': 2, 'B': 1, 'C': 9}, \
        {'A': 2, 'B': 1, 'C': 10}, \
        {'A': 2, 'B': 2} \
    ]
    aggregation = { \
        'categories': ['A', 'B'], \
        'measures': [ \
            {'field': 'C', 'function': 'sum'} \
        ] \
    }
    result = dataAggregate(data, aggregation)
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': 1, 'C': 11}, \
        {'A': 1, 'B': 2, 'C': 15}, \
        {'A': 2, 'B': 1, 'C': 19}, \
        {'A': 2, 'B': 2, 'C': null} \
    ])
endfunction
unittestRunTest('testDataAggregate_sum')


function testDataAggregate_invalidModel():
    systemLogDebug('NOTICE: The following "schemaValidate" error is expected:')
    unittestMockAll()
    result = dataAggregate([], {})
    unittestEqual(result, null)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemLogDebug', ['data.bare: dataAggregate - invalid aggregation model']] \
    ])
endfunction
unittestRunTest('testDataAggregate_invalidModel')


#
# dataSort tests
#


function testDataSort():
    data = [ \
        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1, 'C': 6}, \
        {'A': 1}, \
        {'B': 2, 'C': 7}, \
        {'A': 1, 'B': 2, 'C': 8}, \
        {'A': 2, 'B': 1, 'C': 9}, \
        {'A': 2, 'B': 1, 'C': 10}, \
        {'A': 2, 'B': 2} \
    ]
    result = dataSort(data, [['A', true], ['B', false]])
    unittestDeepEqual(result, [ \
        {'A': 2, 'B': 1, 'C': 9}, \
        {'A': 2, 'B': 1, 'C': 10}, \
        {'A': 2, 'B': 2}, \
        {'A': 1}, \
        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1, 'C': 6}, \
        {'A': 1, 'B': 2, 'C': 8}, \
        {'B': 2, 'C': 7} \
    ])
endfunction
unittestRunTest('testDataSort')


#
# dataTop tests
#


function testDataTop():
    data = [ \
        {'A': 'abc', 'B': 1, 'C': 1}, \
        {'A': 'abc', 'B': 1, 'C': 2}, \
        {'A': 'abc', 'B': 1, 'C': 3}, \
        {'A': 'abc', 'B': 2, 'C': 1}, \
        {'A': 'abc', 'B': 2, 'C': 2}, \
        {'A': 'def', 'B': 1, 'C': 1}, \
        {'A': 'ghi', 'C': 1} \
    ]

    result1 = dataTop(data, 2, ['A', 'B'])
    unittestDeepEqual(result1, [ \
        {'A': 'abc', 'B': 1, 'C': 1}, \
        {'A': 'abc', 'B': 1, 'C': 2}, \
        {'A': 'abc', 'B': 2, 'C': 1}, \
        {'A': 'abc', 'B': 2, 'C': 2}, \
        {'A': 'def', 'B': 1, 'C': 1}, \
        {'A': 'ghi', 'C': 1} \
    ])

    result2 = dataTop(data, 1, ['A'])
    unittestDeepEqual(result2, [ \
        {'A': 'abc', 'B': 1, 'C': 1}, \
        {'A': 'def', 'B': 1, 'C': 1}, \
        {'A': 'ghi', 'C': 1} \
    ])

    result3 = dataTop(data, 3)
    unittestDeepEqual(result3, [ \
        {'A': 'abc', 'B': 1, 'C': 1}, \
        {'A': 'abc', 'B': 1, 'C': 2}, \
        {'A': 'abc', 'B': 1, 'C': 3} \
    ])
endfunction
unittestRunTest('testDataTop')
