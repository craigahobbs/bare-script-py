#
# dataJoin tests
#


function testJoinData():
    leftData = [ \
        {'a': 1, 'b': 5}, \
        {'a': 1, 'b': 6}, \
        {'a': 2, 'b': 7}, \
        {'a': 3, 'b': 8} \
    ]
    rightData = [ \
        {'a': 1, 'c': 10}, \
        {'a': 2, 'c': 11}, \
        {'a': 2, 'c': 12} \
    ]
    result = dataJoin(leftData, rightData, 'a')
    unittestDeepEqual(result, [ \
        {'a': 1, 'b': 5, 'a2': 1, 'c': 10}, \
        {'a': 1, 'b': 6, 'a2': 1, 'c': 10}, \
        {'a': 2, 'b': 7, 'a2': 2, 'c': 11}, \
        {'a': 2, 'b': 7, 'a2': 2, 'c': 12}, \
        {'a': 3, 'b': 8} \
    ])
endfunction
unittestRunTest('testJoinData')


function testJoinData_left():
    leftData = [ \
        {'a': 1, 'b': 5}, \
        {'a': 2, 'b': 7} \
    ]
    rightData = [ \
        {'a': 1, 'c': 10} \
    ]
    result = dataJoin(leftData, rightData, 'a')
    unittestDeepEqual(result, [ \
        {'a': 1, 'b': 5, 'a2': 1, 'c': 10}, \
        {'a': 2, 'b': 7} \
    ])

    resultLeft = dataJoin(leftData, rightData, 'a', null, true)
    unittestDeepEqual(resultLeft, [ \
        {'a': 1, 'b': 5, 'a2': 1, 'c': 10} \
    ])
endfunction
unittestRunTest('testJoinData_left')


function testJoinData_variables():
    leftData = [ \
        {'a': 1, 'b': 5}, \
        {'a': 1, 'b': 6}, \
        {'a': 2, 'b': 7} \
    ]
    rightData = [ \
        {'a': 2, 'c': 10}, \
        {'a': 4, 'c': 11}, \
        {'a': 4, 'c': 12} \
    ]
    result = dataJoin(leftData, rightData, 'a', 'a / denominator', null, {'denominator': 2})
    unittestDeepEqual(result, [ \
        {'a': 1, 'b': 5, 'a2': 2, 'c': 10}, \
        {'a': 1, 'b': 6, 'a2': 2, 'c': 10}, \
        {'a': 2, 'b': 7, 'a2': 4, 'c': 11}, \
        {'a': 2, 'b': 7, 'a2': 4, 'c': 12} \
    ])
endfunction
unittestRunTest('testJoinData_variables')


function testJoinData_unique():
    leftData = [ \
        {'a': 1, 'b': 5}, \
        {'a': 1, 'b': 6}, \
        {'a': 2, 'b': 7}, \
        {'a': 3, 'b': 8} \
    ]
    rightData = [ \
        {'a': 1, 'a2': 0, 'c': 10}, \
        {'a': 2, 'a2': 0, 'c': 11}, \
        {'a': 2, 'a2': 0, 'c': 12} \
    ]
    result = dataJoin(leftData, rightData, 'a')
    unittestDeepEqual(result, [ \
        {'a': 1, 'b': 5, 'a2': 0, 'a3': 1, 'c': 10}, \
        {'a': 1, 'b': 6, 'a2': 0, 'a3': 1, 'c': 10}, \
        {'a': 2, 'b': 7, 'a2': 0, 'a3': 2, 'c': 11}, \
        {'a': 2, 'b': 7, 'a2': 0, 'a3': 2, 'c': 12}, \
        {'a': 3, 'b': 8} \
    ])
endfunction
unittestRunTest('testJoinData_unique')


#
# dataCalculatedField tests
#


function testAddCalculatedField():
    data = [ \
        {'A': 1, 'B': 5}, \
        {'A': 2, 'B': 6} \
    ]
    result = dataCalculatedField(data, 'C', 'A * B')
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': 5, 'C': 5}, \
        {'A': 2, 'B': 6, 'C': 12} \
    ])
endfunction
unittestRunTest('testAddCalculatedField')


function testAddCalculatedField_variables():
    data = [ \
        {'A': 1}, \
        {'A': 2} \
    ]
    result = dataCalculatedField(data, 'C', 'A * B', {'B': 5})
    unittestDeepEqual(result, [ \
        {'A': 1, 'C': 5}, \
        {'A': 2, 'C': 10} \
    ])
endfunction
unittestRunTest('testAddCalculatedField_variables')


