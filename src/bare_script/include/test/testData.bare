include '../data.bare'
include '../unittest.bare'
include '../unittestMock.bare'


#
# dataParseCSV tests
#


function testParseCSV():
    unittestMockAll()
    data = dataParseCSV( \
        'ColumnA,Column B,ColumnC,ColumnD\n' + \
        '1,abc,"10","xyz"\n' + \
        '2,def,"11","pdq"\n' \
    )
    unittestDeepEqual(data, [ \
        {'ColumnA': 1, 'Column B': 'abc', 'ColumnC': 10, 'ColumnD': 'xyz'}, \
        {'ColumnA': 2, 'Column B': 'def', 'ColumnC': 11, 'ColumnD': 'pdq'} \
    ])
    unittestDeepEqual(unittestMockEnd(), [])
endfunction
unittestRunTest('testParseCSV')


function testParseCSV_array():
    data = dataParseCSV([ \
        'A,B\na1,b1', \
        'a2,b2' \
    ])
    unittestDeepEqual(data, [ \
        {'A': 'a1', 'B': 'b1'}, \
        {'A': 'a2', 'B': 'b2'} \
    ])
endfunction
unittestRunTest('testParseCSV_array')


function testParseCSV_shortRow():
    data = dataParseCSV( \
        'A,B\n' + \
        'a1,b1\n' + \
        'a2\n' \
    )
    unittestDeepEqual(data, [ \
        {'A': 'a1', 'B': 'b1'}, \
        {'A': 'a2', 'B': null} \
    ])
endfunction
unittestRunTest('testParseCSV_shortRow')


function testParseCSV_blankLines():
    data = dataParseCSV([ \
        'A,B', \
        '  ', \
        'a1,b1', \
        '', \
        'a2,b2' \
    ])
    unittestDeepEqual(data, [ \
        {'A': 'a1', 'B': 'b1'}, \
        {'A': 'a2', 'B': 'b2'} \
    ])
endfunction
unittestRunTest('testParseCSV_blankLines')


function testParseCSV_quotes():
    data = dataParseCSV( \
        'A,B\n' + \
        '"a,1",b1\n' + \
        'a2,"b,2"\n' \
    )
    unittestDeepEqual(data, [ \
        {'A': 'a,1', 'B': 'b1'}, \
        {'A': 'a2', 'B': 'b,2'} \
    ])
endfunction
unittestRunTest('testParseCSV_quotes')


function testParseCSV_quotesEscaped():
    data = dataParseCSV( \
        'A,B\n' + \
        '"a,""1""",b1\n' + \
        'a2,"b,""2"""\n' \
    )
    unittestDeepEqual(data, [ \
        {'A': 'a,"1"', 'B': 'b1'}, \
        {'A': 'a2', 'B': 'b,"2"'} \
    ])
endfunction
unittestRunTest('testParseCSV_quotesEscaped')


function testParseCSV_spaces():
    data = dataParseCSV([ \
        'A,B', \
        ' a1,b1 ', \
        ' "a2","b2" ' \
    ])
    unittestDeepEqual(data, [ \
        {'A': ' a1', 'B': 'b1 '}, \
        {'A': ' "a2"', 'B': 'b2'} \
    ])
endfunction
unittestRunTest('testParseCSV_spaces')


function testParseCSV_emptyFile():
    data = dataParseCSV('')
    unittestDeepEqual(data, [])
endfunction
unittestRunTest('testParseCSV_emptyFile')


#
# dataValidate tests
#


function testValidateData():
    data = [ \
        {'A': 1, 'B': '5', 'C': 10}, \
        {'A': 2, 'B': '6', 'C': null}, \
        {'A': 3, 'B': '7', 'C': null} \
    ]
    result = dataValidate(data)
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': '5', 'C': 10}, \
        {'A': 2, 'B': '6', 'C': null}, \
        {'A': 3, 'B': '7', 'C': null} \
    ])
endfunction
unittestRunTest('testValidateData')


function testValidateData_csv():
    data = [ \
        {'A': 1, 'B': '5', 'C': 10}, \
        {'A': 2, 'B': 6, 'C': null}, \
        {'A': 3, 'B': '7', 'C': 'null'}, \
        {'A': 4, 'B': 8, 'C': ''} \
    ]
    result = dataValidate(data, true)
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': 5, 'C': 10}, \
        {'A': 2, 'B': 6, 'C': null}, \
        {'A': 3, 'B': 7, 'C': null}, \
        {'A': 4, 'B': 8, 'C': null} \
    ])
endfunction
unittestRunTest('testValidateData_csv')


function testValidateData_datetime():
    data = [ \
        {'date': datetimeISOParse('2022-08-30T00:00:00Z')}, \
        {'date': '2022-08-30'}, \
        {'date': '2022-08-30T11:04:00Z'}, \
        {'date': null} \
    ]
    result = dataValidate(data, true)
    unittestDeepEqual(result, [ \
        {'date': datetimeISOParse('2022-08-30T00:00:00Z')}, \
        {'date': datetimeISOParse('2022-08-30')}, \
        {'date': datetimeISOParse('2022-08-30T11:04:00Z')}, \
        {'date': null} \
    ])
endfunction
unittestRunTest('testValidateData_datetime')


function testValidateData_datetimeString():
    data = [ \
        {'date': '2022-08-30'}, \
        {'date': datetimeISOParse('2022-08-30T00:00:00Z')}, \
        {'date': '2022-08-30T11:04:00Z'}, \
        {'date': null}, \
        {'date': 'null'}, \
        {'date': ''} \
    ]
    result = dataValidate(data, true)
    unittestDeepEqual(result, [ \
        {'date': datetimeISOParse('2022-08-30')}, \
        {'date': datetimeISOParse('2022-08-30T00:00:00Z')}, \
        {'date': datetimeISOParse('2022-08-30T11:04:00Z')}, \
        {'date': null}, \
        {'date': null}, \
        {'date': null} \
    ])
endfunction
unittestRunTest('testValidateData_datetimeString')


function testValidateData_bool():
    data = [ \
        {'A': 1, 'B': true}, \
        {'A': 2, 'B': false}, \
        {'A': 3, 'B': 'true'}, \
        {'A': 4, 'B': 'false'}, \
        {'A': 5, 'B': null} \
    ]
    result = dataValidate(data, true)
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': true}, \
        {'A': 2, 'B': false}, \
        {'A': 3, 'B': true}, \
        {'A': 4, 'B': false}, \
        {'A': 5, 'B': null} \
    ])
endfunction
unittestRunTest('testValidateData_bool')


function testValidateData_boolString():
    data = [ \
        {'A': 1, 'B': 'true'}, \
        {'A': 2, 'B': 'false'}, \
        {'A': 3, 'B': true}, \
        {'A': 4, 'B': false}, \
        {'A': 5, 'B': null}, \
        {'A': 5, 'B': 'null'}, \
        {'A': 5, 'B': ''} \
    ]
    result = dataValidate(data, true)
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': true}, \
        {'A': 2, 'B': false}, \
        {'A': 3, 'B': true}, \
        {'A': 4, 'B': false}, \
        {'A': 5, 'B': null}, \
        {'A': 5, 'B': null}, \
        {'A': 5, 'B': null} \
    ])
endfunction
unittestRunTest('testValidateData_boolString')


function testValidateData_undetermined():
    data = [ \
        {'A': '', 'B': 'null'}, \
        {'A': 2, 'B': ''} \
    ]
    result = dataValidate(data, true)
    unittestDeepEqual(result, [ \
        {'A': null, 'B': null}, \
        {'A': 2, 'B': ''} \
    ])
endfunction
unittestRunTest('testValidateData_undetermined')


function testValidateData_numberError():
    unittestMockAll()
    data = [ \
        {'A': 1}, \
        {'A': '2'} \
    ]
    result = dataValidate(data)
    unittestEqual(result, null)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemLogDebug', ['data: dataValidate - invalid "A" field value, expected type number']] \
    ])
endfunction
unittestRunTest('testValidateData_numberError')


