function testAggregateData_stddev():
    data = [ \
        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1, 'C': 6}, \
        {'A': 1, 'B': 1}, \
        {'A': 1, 'B': 2, 'C': 7}, \
        {'A': 1, 'B': 2, 'C': 10}, \
        {'A': 2, 'B': 1, 'C': 5}, \
        {'A': 2, 'B': 1, 'C': 10}, \
        {'A': 2, 'B': 2} \
    ]
    aggregation = { \
        'categories': ['A', 'B'], \
        'measures': [ \
            {'field': 'C', 'function': 'stddev'} \
        ] \
    }
    result = dataAggregate(data, aggregation)
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': 1, 'C': 0.5}, \
        {'A': 1, 'B': 2, 'C': 1.5}, \
        {'A': 2, 'B': 1, 'C': 2.5}, \
        {'A': 2, 'B': 2, 'C': null} \
    ])
endfunction
unittestRunTest('testAggregateData_stddev')


function testAggregateData_sum():
