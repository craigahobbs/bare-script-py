        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1, 'C': 6}, \
        {'A': 1, 'B': 1}, \
        {'A': 1, 'B': 2, 'C': 7}, \
        {'A': 1, 'B': 2, 'C': 8}, \
        {'A': 2, 'B': 1, 'C': 9}, \
        {'A': 2, 'B': 1, 'C': 10}, \
        {'A': 2, 'B': 2} \
    ]
    aggregation = { \
        'categories': ['A', 'B'], \
        'measures': [ \
            {'field': 'C', 'function': 'sum'} \
        ] \
    }
    result = dataAggregate(data, aggregation)
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': 1, 'C': 11}, \
        {'A': 1, 'B': 2, 'C': 15}, \
        {'A': 2, 'B': 1, 'C': 19}, \
        {'A': 2, 'B': 2, 'C': null} \
    ])
endfunction
unittestRunTest('testAggregateData_sum')


function testAggregateData_invalidModel():
    systemLogDebug('NOTICE: The following "schemaValidate" error is expected:')
    unittestMockAll()
    result = dataAggregate([], {})
    unittestEqual(result, null)
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemLogDebug', ['data: dataAggregate - invalid aggregation model']] \
    ])
endfunction
unittestRunTest('testAggregateData_invalidModel')


#
# dataSort tests
