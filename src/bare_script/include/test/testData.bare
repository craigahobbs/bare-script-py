function testSortData():
    data = [ \
        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1, 'C': 6}, \
        {'A': 1}, \
        {'B': 2, 'C': 7}, \
        {'A': 1, 'B': 2, 'C': 8}, \
        {'A': 2, 'B': 1, 'C': 9}, \
        {'A': 2, 'B': 1, 'C': 10}, \
        {'A': 2, 'B': 2} \
    ]
    result = dataSort(data, [['A', true], ['B', false]])
    unittestDeepEqual(result, [ \
        {'A': 2, 'B': 1, 'C': 9}, \
        {'A': 2, 'B': 1, 'C': 10}, \
        {'A': 2, 'B': 2}, \
        {'A': 1}, \
        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1, 'C': 6}, \
        {'A': 1, 'B': 2, 'C': 8}, \
        {'B': 2, 'C': 7} \
    ])
endfunction
unittestRunTest('testSortData')


#
# dataTop tests
#


function testTopData():
    data = [ \
        {'A': 'abc', 'B': 1, 'C': 1}, \
        {'A': 'abc', 'B': 1, 'C': 2}, \
        {'A': 'abc', 'B': 1, 'C': 3}, \
        {'A': 'abc', 'B': 2, 'C': 1}, \
        {'A': 'abc', 'B': 2, 'C': 2}, \
        {'A': 'def', 'B': 1, 'C': 1}, \
        {'A': 'ghi', 'C': 1} \
    ]

    result1 = dataTop(data, 2, ['A', 'B'])
    unittestDeepEqual(result1, [ \
        {'A': 'abc', 'B': 1, 'C': 1}, \
        {'A': 'abc', 'B': 1, 'C': 2}, \
        {'A': 'abc', 'B': 2, 'C': 1}, \
        {'A': 'abc', 'B': 2, 'C': 2}, \
        {'A': 'def', 'B': 1, 'C': 1}, \
        {'A': 'ghi', 'C': 1} \
    ])

    result2 = dataTop(data, 1, ['A'])
    unittestDeepEqual(result2, [ \
        {'A': 'abc', 'B': 1, 'C': 1}, \
        {'A': 'def', 'B': 1, 'C': 1}, \
        {'A': 'ghi', 'C': 1} \
    ])

    result3 = dataTop(data, 3)
    unittestDeepEqual(result3, [ \
        {'A': 'abc', 'B': 1, 'C': 1}, \
        {'A': 'abc', 'B': 1, 'C': 2}, \
        {'A': 'abc', 'B': 1, 'C': 3} \
    ])
endfunction
unittestRunTest('testTopData')
