function testDataFilter():
    data = [ \
        {'A': 1, 'B': 5}, \
        {'A': 6, 'B': 2}, \
        {'A': 3, 'B': 7} \
    ]
    result = dataFilter(data, 'A > B')
    unittestDeepEqual(result, [ \
        {'A': 6, 'B': 2} \
    ])
endfunction
unittestRunTest('testDataFilter')


function testDataFilter_variables():
    data = [ \
        {'A': 1, 'B': 5}, \
        {'A': 6, 'B': 2}, \
        {'A': 3, 'B': 7} \
    ]
    result = dataFilter(data, 'A > test', {'test': 5})
    unittestDeepEqual(result, [ \
        {'A': 6, 'B': 2} \
    ])
endfunction
unittestRunTest('testDataFilter_variables')


#
# dataAggregate tests
#


function testDataAggregate():
    data = [ \
        {'A': 1, 'B': 1, 'C': 4}, \
        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1} \
    ]
    aggregation = { \
        'measures': [ \
            {'field': 'C', 'function': 'average'} \
        ] \
    }
    result = dataAggregate(data, aggregation)
    unittestDeepEqual(result, [ \
        {'C': 4.5} \
    ])
endfunction
unittestRunTest('testDataAggregate')


function testDataAggregate_categories():
    data = [ \
        {'A': 1, 'B': 1, 'C': 4}, \
        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1}, \
        {'A': 1, 'B': 2, 'C': 7}, \
        {'A': 1, 'B': 2, 'C': 8}, \
        {'A': 2, 'B': 1, 'C': 9}, \
        {'A': 2, 'B': 1, 'C': 10}, \
        {'A': 2, 'B': 2} \
    ]
    aggregation = { \
        'categories': ['A', 'B'], \
        'measures': [ \
            {'field': 'C', 'function': 'average'}, \
            {'field': 'C', 'function': 'average', 'name': 'Average(C)'} \
        ] \
    }
    result = dataAggregate(data, aggregation)
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': 1, 'C': 4.5, 'Average(C)': 4.5}, \
        {'A': 1, 'B': 2, 'C': 7.5, 'Average(C)': 7.5}, \
        {'A': 2, 'B': 1, 'C': 9.5, 'Average(C)': 9.5}, \
        {'A': 2, 'B': 2, 'C': null, 'Average(C)': null} \
    ])
endfunction
unittestRunTest('testDataAggregate_categories')


function testDataAggregate_count():
    data = [ \
        {'A': 1, 'B': 1, 'C': 5}, \
        {'A': 1, 'B': 1, 'C': 6}, \
        {'A': 1, 'B': 1}, \
        {'A': 1, 'B': 2, 'C': 7}, \
        {'A': 1, 'B': 2, 'C': 8}, \
        {'A': 2, 'B': 1, 'C': 9}, \
        {'A': 2, 'B': 1, 'C': 10}, \
        {'A': 2, 'B': 2} \
    ]
    aggregation = { \
        'categories': ['A', 'B'], \
        'measures': [ \
            {'field': 'C', 'function': 'count'} \
        ] \
    }
    result = dataAggregate(data, aggregation)
    unittestDeepEqual(result, [ \
        {'A': 1, 'B': 1, 'C': 2}, \
        {'A': 1, 'B': 2, 'C': 2}, \
        {'A': 2, 'B': 1, 'C': 2}, \
        {'A': 2, 'B': 2, 'C': null} \
    ])
endfunction
unittestRunTest('testDataAggregate_count')


