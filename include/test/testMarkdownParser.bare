    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h2', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h3', 'spans': [{'text': 'bar'}]}}, \
                {'paragraph': {'style': 'h3', 'spans': [{'text': 'foo'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingClosingCharacters')


function testMarkdownParse_headingClosingCharactersLength():
