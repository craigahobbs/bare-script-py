            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingAlternateLength')


function testMarkdownParse_headingAlternateIndented():
    markdown = markdownParse([ \
        '   Foo', \
        '---', \
        '', \
        '  Foo', \
        '-----', \
        '', \
        '  Foo', \
        '  ===' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h2', 'spans': [{'text': '   Foo'}]}}, \
                {'paragraph': {'style': 'h2', 'spans': [{'text': '  Foo'}]}}, \
                {'paragraph': {'style': 'h1', 'spans': [{'text': '  Foo'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingAlternateIndented')


