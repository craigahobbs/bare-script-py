    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'table': { \
                    'headers': [[{'text': 'abc'}], [{'text': 'defghi'}]], \
                    'aligns': ['center', 'right'], \
                    'rows': [ \
                        [[{'text': 'bar'}], [{'text': 'baz'}]] \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
