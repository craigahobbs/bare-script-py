function testMarkdownParse_headingEmpty():
    markdown = markdownParse([ \
        '## ', \
        '#', \
        '### ###' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h2', 'spans': []}}, \
                {'paragraph': {'spans': [{'text': '#'}]}}, \
                {'paragraph': {'style': 'h3', 'spans': [{'text': '###'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingEmpty')


function testMarkdownParse_headingAlternate():
    markdown = markdownParse([ \
        'Title *Emphasis*', \
        '================', \
        '', \
        'This is a sentence.', \
        '', \
        'Subtitle *Emphasis*', \
        '-------------------', \
        '', \
        'Some words.' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h1', 'spans': [ \
                    {'text': 'Title '}, \
                    {'style': {'style': 'italic', 'spans': [{'text': 'Emphasis'}]}} \
                ]}}, \
                {'paragraph': {'spans': [{'text': 'This is a sentence.'}]}}, \
                {'paragraph': {'style': 'h2', 'spans': [ \
                    {'text': 'Subtitle '}, \
                    {'style': {'style': 'italic', 'spans': [{'text': 'Emphasis'}]}} \
                ]}}, \
                {'paragraph': {'spans': [{'text': 'Some words.'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingAlternate')


function testMarkdownParse_headingAlternateMultiline():
    markdown = markdownParse([ \
        'Title', \
        '*and* More', \
        '  ===' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h1', 'spans': [ \
                    {'text': 'Title\n'}, \
                    {'style': {'style': 'italic', 'spans': [{'text': 'and'}]}}, \
                    {'text': ' More'} \
                ]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingAlternateMultiline')


function testMarkdownParse_headingAlternateLength():
