include '../markdownParser.bare'
include '../unittest.bare'


function testMarkdownParse():
    markdown = markdownParse([ \
        '# Title', \
        '', \
        'This is a sentence.', \
        'This is another sentence.', \
        '', \
        '', \
        'This is another paragraph.' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'Title'}], 'style': 'h1'}}, \
                {'paragraph': {'spans': [{'text': 'This is a sentence.\nThis is another sentence.'}]}}, \
                {'paragraph': {'spans': [{'text': 'This is another paragraph.'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse')


function testMarkdownParse_lines():
    markdown = markdownParse([ \
        '# Title', \
        '', \
        'This is a sentence.', \
        'This is another sentence.', \
        null, \
        '', \
        'This is another paragraph.\n\nAnd another.' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'Title'}], 'style': 'h1'}}, \
                {'paragraph': {'spans': [{'text': 'This is a sentence.\nThis is another sentence.'}]}}, \
                {'paragraph': {'spans': [{'text': 'This is another paragraph.'}]}}, \
                {'paragraph': {'spans': [{'text': 'And another.'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_lines')


function testMarkdownParse_tabs():
    markdown = markdownParse([ \
        'This is a tab "\t".', \
        '', \
        ' * List 1 - 1', \
        '\t* List 2 - 1', \
        '\t* List 2 - 2' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'This is a tab "    ".'}]}}, \
                {'list': {'items': [ \
                    {'parts': [ \
                        {'paragraph': {'spans': [{'text': 'List 1 - 1'}]}}, \
                        {'list': {'items': [ \
                            {'parts': [ \
                                {'paragraph': {'spans': [{'text': 'List 2 - 1'}]}} \
                            ]}, \
                            {'parts': [ \
                                {'paragraph': {'spans': [{'text': 'List 2 - 2'}]}} \
                            ]} \
                        ]}} \
                    ]} \
                ]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_tabs')


function testMarkdownParse_empty():
    markdown = markdownParse('')
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_empty')


function testMarkdownParse_horizontalRule():
    markdown = markdownParse([ \
        'Some text', \
        '***', \
        '******', \
        'More text' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'Some text'}]}}, \
                {'hr': 1}, \
                {'hr': 1}, \
                {'paragraph': {'spans': [{'text': 'More text'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_horizontalRule')


function testMarkdownParse_horizontalRuleVariety():
    markdown = markdownParse([ \
        '***', \
        '---', \
        '___' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'hr': 1}, \
                {'hr': 1}, \
                {'hr': 1} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_horizontalRuleVariety')


function testMarkdownParse_horizontalRuleNotEnoughCharacters():
    markdown = markdownParse([ \
        '--', \
        '**', \
        '__' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': '--\n**\n__'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_horizontalRuleNotEnoughCharacters')


function testMarkdownParse_horizontalRuleInitialSpace():
    markdown = markdownParse([ \
        ' ***', \
        '  ***', \
        '   ***', \
        '    ***' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'hr': 1}, \
                {'hr': 1}, \
                {'hr': 1}, \
                {'codeBlock': { \
                    'lines': ['***'], \
                    'startLineNumber': 4 \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_horizontalRuleInitialSpace')


function testMarkdownParse_horizontalRuleMoreThanThreeCharacters():
