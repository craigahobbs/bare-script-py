function testMarkdownParse_tableEscapes():
    markdown = markdownParse([ \
        '| f\\|oo  |', \
        '| ------ |', \
        '| b `\\|` az |', \
        '| b **\\|** im |' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'table': { \
                    'headers': [[{'text': 'f|oo'}]], \
                    'aligns': ['left'], \
                    'rows': [ \
                        [[{'text': 'b '}, {'code': '|'}, {'text': ' az'}]], \
                        [[{'text': 'b '}, {'style': {'style': 'bold', 'spans': [{'text': '|'}]}}, {'text': ' im'}]] \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_tableEscapes')


