function testMarkdownParse_tableListActually():
    markdown = markdownParse([ \
        'A | B', \
        '- | -', \
        '0 | 1' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'A | B'}]}}, \
                {'list': { \
                    'items': [ \
                        { \
                            'parts': [ \
                                {'paragraph': {'spans': [{'text': '| -\n0 | 1'}]}} \
                            ] \
                        } \
                    ] \
                }} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_tableListActually')
