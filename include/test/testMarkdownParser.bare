        'foo', \
        '---', \
        'bar' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'foo'}], 'style': 'h2'}}, \
