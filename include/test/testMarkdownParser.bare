function testMarkdownParse_headingIndent():
    markdown = markdownParse([ \
        ' ### foo', \
        '  ## foo', \
        '   # foo', \
        '    # foo' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h3', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h2', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h1', 'spans': [{'text': 'foo'}]}}, \
                {'codeBlock': {'lines': ['# foo'], 'startLineNumber': 4}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingIndent')


function testMarkdownParse_headingClosingCharacters():
