function testMarkdownParse_heading():
    markdown = markdownParse([ \
        '# foo', \
        '## foo', \
        '### foo', \
        '#### foo', \
        '##### foo', \
        '###### foo', \
        '####### foo' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h1', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h2', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h3', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h4', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h5', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'style': 'h6', 'spans': [{'text': 'foo'}]}}, \
                {'paragraph': {'spans': [{'text': '####### foo'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_heading')


function testMarkdownParse_headingNot():
    markdown = markdownParse([ \
        '#5 bolt', \
        '', \
        '#hashtag' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': '#5 bolt'}]}}, \
                {'paragraph': {'spans': [{'text': '#hashtag'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingNot')


function testMarkdownParse_headingEscape():
    markdown = markdownParse([ \
        '\\## foo' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': '## foo'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingEscape')


function testMarkdownParse_headingSpans():
    markdown = markdownParse([ \
        '# foo *bar* \\*baz\\*' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h1', 'spans': [ \
                    {'text': 'foo '}, \
                    {'style': {'style': 'italic', 'spans': [{'text': 'bar'}]}}, \
                    {'text': ' *baz*'} \
                ]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingSpans')


function testMarkdownParse_headingLeadingTrailingWhitespace():
