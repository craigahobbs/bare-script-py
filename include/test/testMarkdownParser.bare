function testMarkdownParse_headingClosingCharactersEscaped():
    markdown = markdownParse([ \
        '### foo \\###', \
        '## foo #\\##', \
        '# foo \\#' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'style': 'h3', 'spans': [{'text': 'foo ###'}]}}, \
                {'paragraph': {'style': 'h2', 'spans': [{'text': 'foo ###'}]}}, \
                {'paragraph': {'style': 'h1', 'spans': [{'text': 'foo #'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_headingClosingCharactersEscaped')


function testMarkdownParse_headingSeparatesHorizontalRules():
