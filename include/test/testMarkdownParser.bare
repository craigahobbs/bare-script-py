        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'This is a fenced code block:'}]}}, \
                {'codeBlock': { \
                    'lines': [ \
                        '~~~ javascript', \
                        'code 1', \
                        'code 2', \
                        '', \
                        'code 3', \
                        '~~~' \
                    ], \
                    'startLineNumber': 3 \
                }}, \
                {'paragraph': {'spans': [{'text': 'Cool, huh?'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_codeBlockWithFencedCodeBlockText')


