    )
endfunction
unittestRunTest('testMarkdownParse_horizontalRuleMoreThanThreeCharacters')


function testMarkdownParse_horizontalRuleSpaces():
    markdown = markdownParse([ \
        'Some text', \
        ' -  -    --', \
        ' *  *    **', \
        ' _  _    __' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'Some text'}]}}, \
                {'hr': 1}, \
                {'hr': 1}, \
                {'hr': 1} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_horizontalRuleSpaces')


function testMarkdownParse_horizontalRuleBeyondCodeBlock():
    markdown = markdownParse([ \
        '    *****' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'codeBlock': {'lines': ['*****'], 'startLineNumber': 1}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_horizontalRuleBeyondCodeBlock')


function testMarkdownParse_horizontalRuleFollowingCodeBlock():
    markdown = markdownParse([ \
        'This is a horizontal fule immediately following a code block:', \
        '', \
        '    code', \
        '', \
        '---' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'This is a horizontal fule immediately following a code block:'}]}}, \
                {'codeBlock': {'lines': ['code'], 'startLineNumber': 3}}, \
                {'hr': 1} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_horizontalRuleFollowingCodeBlock')


function testMarkdownParse_horizontalRuleSeparatingLists():
    markdown = markdownParse([ \
        '- foo', \
        '***', \
        '- bar' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'list': {'items': [ \
                    {'parts': [ \
                        {'paragraph': {'spans': [{'text': 'foo'}]}} \
                    ]} \
                ]}}, \
                {'hr': 1}, \
                {'list': {'items': [ \
                    {'parts': [ \
                        {'paragraph': {'spans': [{'text': 'bar'}]}} \
                    ]} \
                ]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_horizontalRuleSeparatingLists')


