function testMarkdownParse_codeBlock():
   markdown = markdownParse([ \
        'This is some code:', \
        '', \
        '    code 1', \
        '    code 2', \
        '', \
        '    code 3', \
        '', \
        'Cool, huh?' \
    ])
    unittestDeepEqual( \
        markdownValidate(markdown), \
        { \
            'parts': [ \
                {'paragraph': {'spans': [{'text': 'This is some code:'}]}}, \
                {'codeBlock': {'lines': ['code 1', 'code 2', '', 'code 3'], 'startLineNumber': 3}}, \
                {'paragraph': {'spans': [{'text': 'Cool, huh?'}]}} \
            ] \
        } \
    )
endfunction
unittestRunTest('testMarkdownParse_codeBlock')


function testMarkdownParse_codeBlockWithFencedCodeBlockText():
    markdown = markdownParse([ \
        'This is a fenced code block:', \
        '', \
        '    ~~~ javascript', \
        '    code 1', \
        '    code 2', \
        '', \
        '    code 3', \
        '    ~~~', \
        '', \
        'Cool, huh?' \
    ])
