function testDrawNew():
    drawNew()
    unittestEqual(drawWidth(), 300)
    unittestEqual(drawHeight(), 200)
    unittestDeepEqual(drawElements(), { \
        'svg': 'svg', \
        'attr': {'width': 300, 'height': 200}, \
        'elem': [] \
    })

    drawNew(50, 50)
    unittestEqual(drawWidth(), 50)
    unittestEqual(drawHeight(), 50)
    unittestDeepEqual(drawElements(), { \
        'svg': 'svg', \
        'attr': {'width': 50, 'height': 50}, \
        'elem': [] \
    })
endfunction
unittestRunTest('testDrawNew')


function testDrawRender():
    unittestMockOneGeneric('elementModelRender')
    drawNew()
    drawMove(50, 50)
    drawLine(50, 50)
    drawRender()
    unittestDeepEqual(unittestMockEnd(), [ \
        ['elementModelRender', [ \
            { \
                'html': 'p', \
                'elem': { \
                    'svg': 'svg', \
                    'attr': {'height': 200, 'width': 300}, \
                    'elem': [ \
                        { \
                            'svg': 'path', \
                            'attr': { \
                                'd': 'M 50.00000000 50.00000000 L 50.00000000 50.00000000', \
                                'fill': 'none', \
                                'stroke': 'black', \
                                'stroke-dasharray': 'none', \
                                'stroke-width': 1 \
                            } \
                        } \
                    ] \
                } \
            } \
        ]] \
    ])
endfunction
unittestRunTest('testDrawRender')


function testDrawStyle():
    drawNew(50, 50)
    drawMove(0, 0)
    drawLine(50, 0)
    drawStyle('red')
    drawMove(50, 0)
    drawLine(50, 50)
    drawStyle('red', 2)
    drawMove(50, 50)
    drawLine(0, 50)
    drawStyle('red', 2, 'blue')
    drawMove(0, 50)
    drawLine(0, 0)
    drawStyle('red', 2, 'blue', '4 1')
    drawMove(0, 0)
    drawLine(50, 50)
    unittestDeepEqual(drawElements(), { \
        'svg': 'svg', \
        'attr': {'width': 50, 'height': 50}, \
        'elem': [ \
            { \
                'svg': 'path', \
                'attr': { \
                    'd': 'M 0.00000000 0.00000000 L 50.00000000 0.00000000', \
                    'fill': 'none', \
                    'stroke': 'black', \
                    'stroke-dasharray': 'none', \
                    'stroke-width': 1 \
                } \
            }, \
            { \
                'svg': 'path', \
                'attr': { \
                    'd': 'M 50.00000000 0.00000000 L 50.00000000 50.00000000', \
                    'fill': 'none', \
                    'stroke': 'red', \
                    'stroke-dasharray': 'none', \
                    'stroke-width': 1 \
                } \
            }, \
            { \
                'svg': 'path', \
                'attr': { \
                    'd': 'M 50.00000000 50.00000000 L 0.00000000 50.00000000', \
                    'fill': 'none', \
                    'stroke': 'red', \
                    'stroke-dasharray': 'none', \
                    'stroke-width': 2 \
                } \
            }, \
            { \
                'svg': 'path', \
                'attr': { \
                    'd': 'M 0.00000000 50.00000000 L 0.00000000 0.00000000', \
                    'fill': 'blue', \
                    'stroke': 'red', \
                    'stroke-dasharray': 'none', \
                    'stroke-width': 2 \
                } \
            }, \
            { \
                'svg': 'path', \
                'attr': { \
                    'd': 'M 0.00000000 0.00000000 L 50.00000000 50.00000000', \
                    'fill': 'blue', \
                    'stroke': 'red', \
                    'stroke-dasharray': '4 1', \
                    'stroke-width': 2 \
                } \
            } \
        ] \
    })
endfunction
unittestRunTest('testDrawStyle')


function testDrawStyle_noDrawing():
    drawNew()
    drawStyle('red', 2, 'blue', '4 1')
    drawStyle()
    unittestDeepEqual(drawElements(), { \
        'svg': 'svg', \
        'attr': {'width': 300, 'height': 200}, \
        'elem': [] \
    })
endfunction
unittestRunTest('testDrawStyle_noDrawing')


function testDrawText():
    drawNew(50, 50)
    drawText('Hello', 25, 15)
    drawTextStyle(null, 'black', true, true)
    drawText('World!', 25, 35)
    unittestDeepEqual(drawElements(), { \
        'svg': 'svg', \
        'attr': {'width': 50, 'height': 50}, \
        'elem': [ \
            { \
                'svg': 'text', \
                'attr': { \
                    'x': 25, \
                    'y': 15, \
                    'dominant-baseline': 'middle', \
                    'fill': 'black', \
                    'font-family': 'Arial, Helvetica, sans-serif', \
                    'font-size': '16.00000000', \
                    'font-style': 'normal', \
                    'font-weight': 'normal', \
                    'text-anchor': 'middle' \
                }, \
                'elem': {'text': 'Hello'} \
            }, \
            { \
                'svg': 'text', \
                'attr': { \
                    'x': 25, \
                    'y': 35, \
                    'dominant-baseline': 'middle', \
                    'fill': 'black', \
                    'font-family': 'Arial, Helvetica, sans-serif', \
                    'font-size': '16.00000000', \
                    'font-style': 'italic', \
                    'font-weight': 'bold', \
                    'text-anchor': 'middle' \
                }, \
                'elem': {'text': 'World!'} \
            } \
        ] \
    })
endfunction
unittestRunTest('testDrawText')


function testDrawTextHeight():
    drawNew()
    unittestEqual(mathRound(drawTextHeight('Hello', 50) * 1000) / 1000, 16.667)
    unittestEqual(drawTextHeight('', 0), 16)
endfunction
unittestRunTest('testDrawTextHeight')


function testDrawTextStyle():
    drawNew(50, 50)
    drawText('A', 10, 10)
    drawTextStyle(10, 'red', true, true, 'Comic Sans')
    drawText('B', 20, 20)
    drawTextStyle()
    drawText('C', 30, 30)
    unittestDeepEqual(drawElements(), { \
        'svg': 'svg', \
        'attr': {'width': 50, 'height': 50}, \
        'elem': [ \
            { \
                'svg': 'text', \
                'attr': { \
                    'x': 10, \
                    'y': 10, \
                    'dominant-baseline': 'middle', \
                    'fill': 'black', \
                    'font-family': 'Arial, Helvetica, sans-serif', \
                    'font-size': '16.00000000', \
                    'font-style': 'normal', \
                    'font-weight': 'normal', \
                    'text-anchor': 'middle' \
                }, \
                'elem': {'text': 'A'} \
            }, \
            { \
                'svg': 'text', \
                'attr': { \
                    'x': 20, \
                    'y': 20, \
                    'dominant-baseline': 'middle', \
                    'fill': 'red', \
                    'font-family': 'Comic Sans', \
                    'font-size': '10.00000000', \
                    'font-style': 'italic', \
                    'font-weight': 'bold', \
                    'text-anchor': 'middle' \
                }, \
                'elem': {'text': 'B'} \
            }, \
            { \
                'svg': 'text', \
                'attr': { \
                    'x': 30, \
                    'y': 30, \
                    'dominant-baseline': 'middle', \
                    'fill': 'black', \
                    'font-family': 'Arial, Helvetica, sans-serif', \
                    'font-size': '16.00000000', \
                    'font-style': 'normal', \
                    'font-weight': 'normal', \
                    'text-anchor': 'middle' \
                }, \
                'elem': {'text': 'C'} \
            } \
        ] \
    })
endfunction
unittestRunTest('testDrawTextStyle')


