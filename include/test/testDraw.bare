function testDrawOnClick_clickHandler():
    return 5
endfunction


function testDrawOnClick():
    # Draw a rect and set an on-click event
    drawNew(50, 50)
    drawRect(0, 0, 50, 50)
    drawOnClick(testDrawOnClick_clickHandler)
    elements = drawElements()
    clickHandler = objectGet(objectGet(arrayGet(objectGet(elements, 'elem'), 0), 'callback'), 'click')
    unittestEqual(clickHandler(), 5)
    unittestDeepEqual(elements, { \
        'svg': 'svg', \
        'attr': { \
            'height': 50, \
            'width': 50 \
        }, \
        'elem': [ \
            { \
                'svg': 'rect', \
                'attr': { \
                    'fill': 'none', \
                    'height': 50, \
                    'rx': null, \
                    'ry': null, \
                    'stroke': 'black', \
                    'stroke-dasharray': 'none', \
                    'stroke-width': '1.00000000', \
                    'style': 'cursor: pointer;', \
                    'width': 50, \
                    'x': 0, \
                    'y': 0 \
                }, \
                'callback': { \
                    'click': '<function>' \
                } \
            } \
        ] \
    })
endfunction
unittestRunTest('testDrawOnClick')


function testDrawOnClick_svgClick():
    # Draw a rect and set an on-click event
    drawNew(50, 50)
    drawOnClick(testDrawOnClick_clickHandler)
    drawRect(0, 0, 50, 50)
    elements = drawElements()
    clickHandler = objectGet(objectGet(elements, 'callback'), 'click')
    unittestEqual(clickHandler(), 5)
    unittestDeepEqual(elements, { \
        'svg': 'svg', \
        'attr': { \
            'height': 50, \
            'width': 50, \
            'style': 'cursor: pointer;' \
        }, \
        'elem': [ \
            { \
                'svg': 'rect', \
                'attr': { \
                    'fill': 'none', \
                    'height': 50, \
                    'rx': null, \
                    'ry': null, \
                    'stroke': 'black', \
                    'stroke-dasharray': 'none', \
                    'stroke-width': '1.00000000', \
                    'width': 50, \
                    'x': 0, \
                    'y': 0 \
                } \
            } \
        ], \
        'callback': { \
            'click': '<function>' \
        } \
    })
endfunction
unittestRunTest('testDrawOnClick_svgClick')


