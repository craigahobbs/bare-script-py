include '../draw.bare'
include '../unittest.bare'
include '../unittestMock.bare'


function testDrawAuto():
    systemGlobalSet('drawCurrentDrawing', null)
    drawCircle(25, 25, 25)
    unittestDeepEqual(drawElements(), { \
        'svg': 'svg', \
        'attr': {'width': 300, 'height': 200}, \
        'elem': [ \
            { \
                'svg': 'circle', \
                'attr': { \
                    'cx': 25, \
                    'cy': 25, \
                    'r': 25, \
                    'fill': 'none', \
                    'stroke': 'black', \
                    'stroke-dasharray': 'none', \
                    'stroke-width': '1.00000000' \
                } \
            } \
        ] \
    })
endfunction
unittestRunTest('testDrawAuto')


function testDrawArc():
    drawNew(100, 50)
    drawMove(0, 25)
    drawArc(25, 25, 0, 0, 0, 50, 25)
    drawArc(25, 25, 0, 1, 1, 100, 25)
    unittestDeepEqual(drawElements(), { \
        'svg': 'svg', \
        'attr': {'width': 100, 'height': 50}, \
        'elem': [ \
            { \
                'svg': 'path', \
                'attr': { \
                    'd': 'M 0.00000000 25.00000000 A 25.00000000 25.00000000 0.00000000 0 0 50.00000000 25.00000000 ' + \
                        'A 25.00000000 25.00000000 0.00000000 1 1 100.00000000 25.00000000', \
                    'fill': 'none', \
                    'stroke': 'black', \
                    'stroke-dasharray': 'none', \
                    'stroke-width': 1 \
                } \
            } \
        ] \
    })
endfunction
unittestRunTest('testDrawArc')


