function testDrawImage():
    drawNew(50, 50)
    drawImage(15, 15, 25, 25, '/foo/bar.jpg')
    drawImage(35, 35, 25, 25, 'bar.jpg')
    unittestDeepEqual(drawElements(), { \
        'svg': 'svg', \
        'attr': {'width': 50, 'height': 50}, \
        'elem': [ \
            { \
                'svg': 'image', \
                'attr': { \
                    'height': 25, \
                    'href': '/foo/bar.jpg', \
                    'width': 25, \
                    'x': 15, \
                    'y': 15 \
                } \
            }, \
            { \
                'svg': 'image', \
                'attr': { \
                    'height': 25, \
                    'href': 'bar.jpg', \
                    'width': 25, \
                    'x': 35, \
                    'y': 35 \
                } \
            } \
        ] \
    })
endfunction
unittestRunTest('testDrawImage')


