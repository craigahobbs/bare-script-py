include '../baredoc.bare'
include '../unittest.bare'
include '../unittestMock.bare'


# Test library documentation JSON resources
testBaredocBuiltinJSON = jsonStringify({'functions': [ \
    {'name': 'func_b', 'group': 'A Group', 'doc': ['Test function B']}, \
    {'name': 'func_a', 'group': 'A Group', 'doc': ['Test function A'], \
        'args': [{'name': 'arg1', 'doc': ['The first argument']}, {'name': 'arg2', 'doc': ['The second argument']}], \
        'return': ['The return value']}, \
    {'name': 'func_c', 'group': 'B Group', 'doc': ['Test function C']} \
]})
testBaredocIncludeJSON = jsonStringify({'functions': [ \
    {'name': 'func_d', 'group': 'lib.bare', 'doc': ['Test function D'], 'return': ['The return value']} \
]})


# Test configurations
testBaredocConfig = { \
    'title': 'The Test Library', \
    'sections': [ \
        {'title': 'Builtin Functions', 'url': 'builtin.json'}, \
        {'title': 'Include Functions', 'url': 'include.json'} \
    ] \
}

testBaredocConfigContent = { \
    'title': 'The Test Library', \
    'content': 'index.md', \
    'sections': [ \
        {'title': 'Builtin Functions', 'url': 'builtin.json', \
            'groups': [{'name': 'A Group', 'content': 'a.md', 'description': 'The A functions'}]}, \
        {'title': 'Include Functions', 'url': 'include.json', \
            'groups': [{'name': 'lib.bare', 'description': 'The lib functions'}]} \
    ] \
}


# Test mock fetch data
testBaredocBaseFetch = {'builtin.json': testBaredocBuiltinJSON, 'include.json': testBaredocIncludeJSON}
testBaredocContentFetch = {'builtin.json': testBaredocBuiltinJSON, 'include.json': testBaredocIncludeJSON, \
    'index.md': 'This is the index.', 'a.md': 'These are the A functions.'}


async function testBaredocMain_index():
    # Setup mocks
    unittestMockAll({'systemFetch': testBaredocBaseFetch})

    # Render the index
    baredocMain(testBaredocConfig)

    # Reset mocks
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', [['builtin.json', 'include.json']]], \
        ['documentSetTitle', ['The Test Library']], \
        ['markdownPrint', ['# The Test Library']], \
        ['markdownPrint', ['', '[Single Page](#var.vSingle=true)']], \
        ['markdownPrint', ['', '## Builtin Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ["| [A Group](#var.vGroup='A%20Group'&_top) |  |"]], \
        ['markdownPrint', ["| [B Group](#var.vGroup='B%20Group'&_top) |  |"]], \
        ['markdownPrint', ['', '## Include Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ["| [lib.bare](#var.vGroup='lib.bare'&_top) |  |"]] \
    ])
endfunction
unittestRunTest('testBaredocMain_index')


async function testBaredocMain_index_content():
    # Setup mocks
    unittestMockAll({'systemFetch': testBaredocContentFetch})

    # Render the index
    baredocMain(testBaredocConfigContent)

    # Reset mocks
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', [['builtin.json', 'include.json']]], \
        ['documentSetTitle', ['The Test Library']], \
        ['markdownPrint', ['# The Test Library']], \
        ['systemFetch', ['index.md']], \
        ['markdownPrint', ['', 'This is the index.']], \
        ['markdownPrint', ['', '[Single Page](#var.vSingle=true)']], \
        ['markdownPrint', ['', '## Builtin Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ["| [A Group](#var.vGroup='A%20Group'&_top) | The A functions |"]], \
        ['markdownPrint', ["| [B Group](#var.vGroup='B%20Group'&_top) |  |"]], \
        ['markdownPrint', ['', '## Include Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ["| [lib.bare](#var.vGroup='lib.bare'&_top) | The lib functions |"]] \
    ])
endfunction
unittestRunTest('testBaredocMain_index_content')


async function testBaredocMain_index_contentError():
    # Setup mocks
    unittestMockAll({'systemFetch': testBaredocBaseFetch})

    # Render the index
    baredocMain(testBaredocConfigContent)

    # Reset mocks
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', [['builtin.json', 'include.json']]], \
        ['documentSetTitle', ['The Test Library']], \
        ['markdownPrint', ['# The Test Library']], \
        ['systemFetch', ['index.md']], \
        ['markdownPrint', ['', '**Error:** Failed to load "index.md"']], \
        ['markdownPrint', ['', '[Single Page](#var.vSingle=true)']], \
        ['markdownPrint', ['', '## Builtin Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ["| [A Group](#var.vGroup='A%20Group'&_top) | The A functions |"]], \
        ['markdownPrint', ["| [B Group](#var.vGroup='B%20Group'&_top) |  |"]], \
        ['markdownPrint', ['', '## Include Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ["| [lib.bare](#var.vGroup='lib.bare'&_top) | The lib functions |"]] \
    ])
endfunction
unittestRunTest('testBaredocMain_index_contentError')


async function testBaredocMain_index_unmatchedGroup():
    # A config group with no matching library function group is ignored

    # Setup mocks
    unittestMockAll({'systemFetch': testBaredocBaseFetch})

    # Render the index
    baredocMain({ \
        'title': 'The Test Library', \
        'sections': [ \
            {'title': 'Builtin Functions', 'url': 'builtin.json', \
                'groups': [{'name': 'No Such Group', 'description': 'Ignored'}]}, \
            {'title': 'Include Functions', 'url': 'include.json'} \
        ] \
    })

    # Reset mocks
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', [['builtin.json', 'include.json']]], \
        ['documentSetTitle', ['The Test Library']], \
        ['markdownPrint', ['# The Test Library']], \
        ['markdownPrint', ['', '[Single Page](#var.vSingle=true)']], \
        ['markdownPrint', ['', '## Builtin Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ["| [A Group](#var.vGroup='A%20Group'&_top) |  |"]], \
        ['markdownPrint', ["| [B Group](#var.vGroup='B%20Group'&_top) |  |"]], \
        ['markdownPrint', ['', '## Include Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ["| [lib.bare](#var.vGroup='lib.bare'&_top) |  |"]] \
    ])
endfunction
unittestRunTest('testBaredocMain_index_unmatchedGroup')


async function testBaredocMain_index_configURL():
    # Setup mocks
    unittestMockAll({'systemFetch': {'builtin.json': testBaredocBuiltinJSON, 'include.json': testBaredocIncludeJSON, 'config.json': jsonStringify(testBaredocConfig)}})

    # Render the index
    baredocMain('config.json')

    # Reset mocks
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', ['config.json']], \
        ['systemFetch', [['builtin.json', 'include.json']]], \
        ['documentSetTitle', ['The Test Library']], \
        ['markdownPrint', ['# The Test Library']], \
        ['markdownPrint', ['', '[Single Page](#var.vSingle=true)']], \
        ['markdownPrint', ['', '## Builtin Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ["| [A Group](#var.vGroup='A%20Group'&_top) |  |"]], \
        ['markdownPrint', ["| [B Group](#var.vGroup='B%20Group'&_top) |  |"]], \
        ['markdownPrint', ['', '## Include Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ["| [lib.bare](#var.vGroup='lib.bare'&_top) |  |"]] \
    ])
endfunction
unittestRunTest('testBaredocMain_index_configURL')


async function testBaredocMain_config_invalid():
    systemLogDebug('NOTICE: The following "schemaValidate" error is expected:')

    # Setup mocks
    unittestMockAll({'systemFetch': testBaredocBaseFetch})

    # Render the index
    baredocMain({'title': 'The Test Library'})

    # Reset mocks
    unittestDeepEqual(unittestMockEnd(), [['markdownPrint', ['**Error:** Invalid baredoc configuration']]])
endfunction
unittestRunTest('testBaredocMain_config_invalid')


async function testBaredocMain_section_fetchError():
    # Setup mocks
    unittestMockAll()

    # Render the index
    baredocMain(testBaredocConfig)

    # Reset mocks
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', [['builtin.json', 'include.json']]], \
        ['markdownPrint', ['**Error:** Failed to fetch library documentation resource "builtin.json"']] \
    ])
endfunction
unittestRunTest('testBaredocMain_section_fetchError')


async function testBaredocMain_section_invalid():
    systemLogDebug('NOTICE: The following "schemaValidate" error is expected:')

    # Setup mocks
    unittestMockAll({'systemFetch': {'builtin.json': jsonStringify({'functions': [{'name': 'x', 'group': 'g'}]}), 'include.json': testBaredocIncludeJSON}})

    # Render the index
    baredocMain(testBaredocConfig)

    # Reset mocks
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', [['builtin.json', 'include.json']]], \
        ['markdownPrint', ['**Error:** Failed to fetch library documentation resource "builtin.json"']] \
    ])
endfunction
unittestRunTest('testBaredocMain_section_invalid')


async function testBaredocMain_single():
    # Setup mocks
    unittestMockAll({'systemFetch': testBaredocBaseFetch})

    # Render the index
    systemGlobalSet('vSingle', true)
    baredocMain(testBaredocConfig)
    systemGlobalSet('vSingle', null)

    # Reset mocks
    unittestDeepEqual(unittestMockEnd(), [ \
        ['systemFetch', [['builtin.json', 'include.json']]], \
        ['documentSetTitle', ['The Test Library']], \
        ['markdownPrint', ['# The Test Library']], \
        ['markdownPrint', ['', '[Multi Page](#var=)']], \
        ['markdownPrint', ['', '## Builtin Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ['| [A Group](#var.vSingle=true&a-group) |  |']], \
        ['markdownPrint', ['| [B Group](#var.vSingle=true&b-group) |  |']], \
        ['markdownPrint', ['', '## Include Functions', '']], \
        ['markdownPrint', ['|  |  |', '| --- | --- |']], \
        ['markdownPrint', ['| [lib.bare](#var.vSingle=true&lib-bare) |  |']], \
        ['systemFetch', [[]]], \
        ['markdownPrint', ['', '---', '']], \
        ['markdownPrint', ['## A Group']], \
        ['markdownPrint', ['', '[Back to top](#var.vSingle=true&_top)']], \
        ['markdownPrint', ['', '### Function Index', '']], \
        ['markdownPrint', ['- [func\\_a](#var.vSingle=true&func-a)']], \
        ['markdownPrint', ['- [func\\_b](#var.vSingle=true&func-b)']], \
        ['markdownPrint', ['', '---', '', '### func\\_a', '', ['Test function A']]], \
        ['markdownPrint', ['', '#### Arguments']], \
        ['markdownPrint', ['', '**arg1 -**', ['The first argument']]], \
        ['markdownPrint', ['', '**arg2 -**', ['The second argument']]], \
        ['markdownPrint', ['', '#### Returns']], \
        ['markdownPrint', ['', ['The return value']]], \
        ['markdownPrint', ['', '---', '', '### func\\_b', '', ['Test function B']]], \
        ['markdownPrint', ['', '#### Arguments']], \
        ['markdownPrint', ['', 'None']], \
        ['markdownPrint', ['', '#### Returns']], \
        ['markdownPrint', ['', 'Nothing']], \
        ['markdownPrint', ['', '---', '']], \
        ['markdownPrint', ['## B Group']], \
        ['markdownPrint', ['', '[Back to top](#var.vSingle=true&_top)']], \
        ['markdownPrint', ['', '### Function Index', '']], \
        ['markdownPrint', ['- [func\\_c](#var.vSingle=true&func-c)']], \
        ['markdownPrint', ['', '---', '', '### func\\_c', '', ['Test function C']]], \
        ['markdownPrint', ['', '#### Arguments']], \
        ['markdownPrint', ['', 'None']], \
        ['markdownPrint', ['', '#### Returns']], \
        ['markdownPrint', ['', 'Nothing']], \
        ['markdownPrint', ['', '---', '']], \
        ['markdownPrint', ['## lib.bare']], \
        ['markdownPrint', ['', '[Back to top](#var.vSingle=true&_top)']], \
        ['markdownPrint', ['', '### Function Index', '']], \
        ['markdownPrint', ['- [func\\_d](#var.vSingle=true&func-d)']], \
        ['markdownPrint', ['', '---', '', '### func\\_d', '', ['Test function D']]], \
        ['markdownPrint', ['', '#### Arguments']], \
        ['markdownPrint', ['', 'None']], \
        ['markdownPrint', ['', '#### Returns']], \
        ['markdownPrint', ['', ['The return value']]] \
    ])
endfunction
unittestRunTest('testBaredocMain_single')


