include '../markdownParser.bare'
include '../unittest.bare'


#
# markdownValidate tests
#


function testMarkdownValidate():
    markdownModel = { \
        'parts': [ \
            { \
                'paragraph': { \
                    'style': 'h1', \
                    'spans': [ \
                        {'text': 'This is the '}, \
                        { \
                            'style': { \
                                'style': 'italic', \
                                'spans': [{'text': 'title'}] \
                            } \
                        } \
                    ] \
                } \
            }, \
            { \
                'paragraph': { \
                    'spans': [{'text': 'This is some text'}] \
                } \
            } \
        ] \
    }
    unittestDeepEqual(markdownValidate(markdownModel), markdownModel)
endfunction
unittestRunTest('testMarkdownValidate')


#
# markdownEscape tests
#


function testMarkdownEscape():
    unittestEqual( \
        markdownEscape('Escape me: \\ [ ] ( ) < > " \' * _ ~ ` # | -'), \
        'Escape me: \\\\ \\[ \\] \\( \\) \\< \\> \\" \\\' \\* \\_ \\~ \\` \\# \\| \\-' \
    )
endfunction
unittestRunTest('testMarkdownEscape')


#
# markdownTitle tests
#


function testMarkdownTitle():
    markdownModel = markdownParse( \
        'This is some text\n' + \
        '\n' + \
        '## This is the *title*\n' + \
        '\n' + \
        '# This is NOT the *title*\n' + \
        '\n' + \
        'This is more text\n' \
    )
    unittestEqual(markdownTitle(markdownModel), 'This is the title')
endfunction
unittestRunTest('testMarkdownTitle')


function testMarkdownTitle_link():
    markdownModel = markdownParse( \
        '# This is the [title](about.html)\n' \
    )
    unittestEqual(markdownTitle(markdownModel), 'This is the title')
endfunction
unittestRunTest('testMarkdownTitle_link')


function testMarkdownTitle_image():
    markdownModel = markdownParse( \
        '# This is the ![title](title.jpg)\n' \
    )
    unittestEqual(markdownTitle(markdownModel), 'This is the title')
endfunction
unittestRunTest('testMarkdownTitle_image')


function testMarkdownTitle_noTitle():
    markdownModel = markdownParse( \
        'This is some text\n' + \
        '\n' + \
        'This is more text\n' \
    )
    unittestEqual(markdownTitle(markdownModel), null)
endfunction
unittestRunTest('testMarkdownTitle_noTitle')


#
# markdownParagraphText tests
#


function testMarkdownParagraphText():
    markdownModel = markdownParse( \
        'This is a [link](link.html)\n' + \
        'and some more text\n' + \
        '\n' + \
        'Some other text\n' \
    )
    parts = objectGet(markdownModel, 'parts')
    paragraph = objectGet(arrayGet(parts, 0), 'paragraph')
    unittestEqual(markdownParagraphText(paragraph), 'This is a link\nand some more text')
endfunction
unittestRunTest('testMarkdownParagraphText')
